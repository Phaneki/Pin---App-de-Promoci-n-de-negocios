@{
    Layout = null;
    ViewData["Title"] = "Registro";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Registro - PIN</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500&family=Manrope:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #ff6b2c;
            --primary-soft: #fff2eb;
            --text-dark: #2c2c2c;
            --text-muted: #777;
            --border: #eee;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Manrope', sans-serif;
        }

        body {
            height: 100vh;
            display: flex;
        }

        /* LADO IZQUIERDO */
        .left-panel {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            padding: 60px;
            background: linear-gradient(135deg, #ff6b2c, #ff8a50);
        }

        .headline {
            font-family: 'Playfair Display', serif;
            font-size: 38px;
            line-height: 1.2;
        }

        /* LADO DERECHO */
        .right-panel {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
        }

        .box {
            width: 360px;
            animation: fadeUp 0.6s ease forwards;
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h2 {
            font-size: 28px;
            color: var(--text-dark);
            margin-bottom: 8px;
        }

        .box > p {
            color: var(--text-muted);
            margin-bottom: 25px;
            font-size: 14px;
        }

        input {
            width: 100%;
            padding: 14px;
            border-radius: 10px;
            border: 1px solid var(--border);
            margin-bottom: 15px;
            outline: none;
            transition: all 0.3s ease;
            background: #fafafa;
            font-family: 'Manrope', sans-serif;
        }

        input:focus {
            border-color: var(--primary);
            background: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 107, 44, 0.15);
        }

        .btn {
            width: 100%;
            padding: 13px;
            border-radius: 8px;
            border: none;
            background: var(--primary);
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            margin-bottom: 5px;
        }

        .btn::after {
            content: "";
            position: absolute;
            width: 300%;
            height: 300%;
            top: -100%;
            left: -100%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.3), transparent);
            transition: 0.5s;
        }

        .btn:hover::after {
            top: 0;
            left: 0;
        }

        .btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 15px rgba(255, 107, 44, 0.3);
        }

        .error {
            color: red;
            font-size: 13px;
            margin-top: 10px;
        }

        .extra {
            margin-top: 20px;
            font-size: 13px;
            text-align: center;
            color: var(--text-muted);
        }

        .extra a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }

        .extra a:hover {
            text-decoration: underline;
        }

        /* LOGIN SOCIAL */
        .divider {
            text-align: center;
            margin: 20px 0;
            position: relative;
        }

        .divider span {
            background: white;
            padding: 0 10px;
            color: #999;
            font-size: 13px;
        }

        .divider::before {
            content: "";
            position: absolute;
            width: 100%;
            height: 1px;
            background: #eee;
            top: 50%;
            left: 0;
            z-index: -1;
        }

        .social-login {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .btn-social {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #eee;
            background: white;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.3s ease;
            text-decoration: none;
            color: #2c2c2c;
        }

        .btn-social:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 12px rgba(0, 0, 0, 0.08);
        }

        .google {
            border-color: #db4437;
            color: #db4437;
        }

        .google span {
            font-weight: 700;
            font-size: 18px;
        }

        .google:hover {
            background-color: #f8f8f8;
            border-color: #c1351c;
        }
    </style>
</head>

<body>

    <div class="left-panel">
        <div class="headline">
            Únete a PIN <br> y descubre negocios locales
        </div>
    </div>

    <div class="right-panel">

        <div class="box">

            <h2>Crear cuenta</h2>
            <p>Regístrate para comenzar</p>

            <form method="post">

                <input type="email" name="correo" placeholder="Correo electrónico" required />

                <input type="password" name="password" placeholder="Contraseña" required />

                <input type="password" name="confirmarPassword" placeholder="Confirmar contraseña" required />

                @if (ViewBag.Error != null)
                {
                    <p class="error">@ViewBag.Error</p>
                }

                <button class="btn" type="submit">Registrarse</button>

                <div class="divider">
                    <span>o regístrate con</span>
                </div>

                <div class="social-login">
                    <a asp-controller="Login" asp-action="GoogleLogin" class="btn-social google">
                        <span>G</span> Registrarse con Google
                    </a>
                </div>

            </form>

            <div class="extra">
                ¿Ya tienes cuenta? <a asp-controller="Login" asp-action="Index">Iniciar sesión</a>
            </div>

        </div>

    </div>

</body>
</html>