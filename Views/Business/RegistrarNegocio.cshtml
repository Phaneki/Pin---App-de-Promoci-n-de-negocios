@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Registrar Negocio - Pin";
    var googleMapsApiKey = Configuration["GoogleMaps:ApiKey"];
}
@model PinAppdePromo.Models.Business

@section Styles {
    <!-- Nuestro CSS personalizado -->
    <link rel="stylesheet" href="~/css/registrar-negocio.css" asp-append-version="true" />
}

<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="text-center mb-5">
                <h1 class="main-title">Registra tu negocio y llega a más clientes</h1>
                <p class="text-muted mt-3 fs-5">
                    Completa la información básica para que nuestra comunidad pueda encontrarte
                </p>
            </div>

            <form asp-action="CrearNegocio" asp-controller="Business" method="post" enctype="multipart/form-data" id="formRegistroNegocio">
            <!-- Información básica -->
            <div class="card mb-4">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Nombre del Negocio</label>
                        <input type="text" class="form-control" name="TradeName" placeholder="Ej. El Bodegón del Sur" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Descripción corta</label>
                        <textarea class="form-control" name="Description" rows="3" placeholder="Cuéntanos qué hace especial a tu negocio..." required></textarea>
                    </div>
                    <div>
                        <label class="form-label fw-semibold">Categoría</label>
                        <select class="form-select" name="CategoryId">
                            @if (ViewBag.Categorias != null)
                            {
                                foreach (var cat in ViewBag.Categorias)
                                {
                                    <option value="@cat.CategoryId">@cat.Name</option>
                                }
                            }
                            else
                            {
                                <option value="1">General</option>
                            }
                        </select>
                    </div>
                    <div class="mt-4">
                        <label class="form-label fw-semibold">RUC</label>
                        <input type="text" class="form-control" name="RUC" placeholder="Ej. 20512345678" maxlength="11">
                    </div>
                    <div class="mt-4">
                        <label class="form-label fw-semibold">Teléfono de contacto</label>
                        <input type="tel" class="form-control" name="ContactPhone" placeholder="Ej. 987654321">
                    </div>
                </div>
            </div>

            <!-- Ubicación -->
            <div class="card mb-4">
                <div class="card-body p-5">
                    <p class="section-label">Ubicación</p>
                    <div class="mt-3">
                        <label class="form-label fw-semibold">Dirección exacta</label>
                        <input type="text" class="form-control" id="addressInput" name="Address" placeholder="Calle, número, distrito..." required>
                    </div>
                    <div class="mt-4 border rounded-4 overflow-hidden">
                        <div id="map"></div>
                    </div>
                    <input type="hidden" id="latitude" name="Latitude" />
                    <input type="hidden" id="longitude" name="Longitude" />
                </div>
            </div>

            <!-- Imágenes del Negocio -->
            <div class="card mb-4">
                <div class="card-body p-5">
                    <p class="section-label">Imágenes del Negocio</p>
                    
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Opción 1: Ingresa el link de una imagen de internet</label>
                        <input type="url" class="form-control" name="ImageUrlLink" placeholder="Ej. https://images.unsplash.com/photo-...">
                        <small class="text-muted">Si ingresas un link, ayudarás a que la app sea mucho más rápida y liviana.</small>
                    </div>
                    
                    <div class="text-center mb-3 text-muted fw-bold">Ó</div>
                    
                    <label class="form-label fw-semibold">Opción 2: Sube un archivo desde tu computadora</label>
                    <div class="border border-dashed rounded-4 p-5 text-center mt-2" style="background: #f8fafc;">
                        <div class="mx-auto mb-3" style="width: 60px; height: 60px; background: #fee2e2; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                            📸
                        </div>
                        <p class="fw-medium">Arrastra tus fotos aquí</p>
                        <small class="text-muted">O haz clic para seleccionar archivos (JPG, PNG hasta 10MB)</small>
                        <input type="file" name="Imagenes" multiple class="form-control mt-3" accept="image/*" />
                    </div>
                </div>
            </div>

            <!-- Horarios de Atención -->
            <div class="card mb-5">
                <div class="card-body p-5">
                    <p class="section-label">Horarios de Atención</p>
                    <div class="row g-3 mt-2">
                        <!-- Lunes a Viernes -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">LUNES - VIERNES</label>
                            <div class="time-input-group">
                                <input type="time" class="form-control" id="lv_inicio" value="09:00">
                                <span>hasta</span>
                                <input type="time" class="form-control" id="lv_fin" value="18:00">
                            </div>
                        </div>

                        <!-- Sábados -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">SÁBADOS</label>
                            <div class="time-input-group">
                                <input type="time" class="form-control" id="s_inicio" value="10:00">
                                <span>hasta</span>
                                <input type="time" class="form-control" id="s_fin" value="14:00">
                            </div>
                        </div>

                        <!-- Domingos -->
                        <div class="col-12">
                            <label class="form-label fw-semibold">DOMINGOS</label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="domingo" id="domingo_cerrado" checked>
                                    <label class="form-check-label" for="domingo_cerrado">
                                        Cerrado
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="domingo" id="domingo_abierto">
                                    <label class="form-check-label" for="domingo_abierto">
                                        Abierto
                                    </label>
                                </div>
                            </div>
                            <div class="time-input-group mt-3" id="domingo_horarios" style="display:none;">
                                <input type="time" class="form-control" id="d_inicio" value="10:00">
                                <span>hasta</span>
                                <input type="time" class="form-control" id="d_fin" value="18:00">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botón Enviar -->
            <div class="d-grid">
                <button type="submit" class="btn btn-enviar btn-lg">
                    ➜ Enviar para aprobación
                </button>
            </div>
            </form>

            <p class="text-center text-muted small mt-4">
                AL ENVIAR, ACEPTAS NUESTROS TÉRMINOS Y CONDICIONES DE SERVICIO.
            </p>

        </div>
    </div>
</div>

<!-- Google Maps API -->
<script src="https://maps.googleapis.com/maps/api/js?key=@googleMapsApiKey&libraries=places&callback=initMap" async defer></script>

<script>
    let map;
    let marker;
    let geocoder;
    const defaultLocation = { lat: -12.0464, lng: -77.0428 }; // Lima, Perú

    // Inicializar el mapa
    function initMap() {
        geocoder = new google.maps.Geocoder();
        
        map = new google.maps.Map(document.getElementById('map'), {
            center: defaultLocation,
            zoom: 13,
            mapTypeControl: false,
            streetViewControl: false
        });

        // Crear marcador arrastrable
        marker = new google.maps.Marker({
            position: defaultLocation,
            map: map,
            draggable: true,
            title: 'Ubica tu negocio aquí'
        });

        // Evento al arrastrar el marcador
        marker.addListener('dragend', function() {
            const position = marker.getPosition();
            updateCoordinates(position.lat(), position.lng());
            geocodePosition(position);
        });

        // Evento al hacer clic en el mapa
        map.addListener('click', function(event) {
            marker.setPosition(event.latLng);
            updateCoordinates(event.latLng.lat(), event.latLng.lng());
            geocodePosition(event.latLng);
        });

        // Configurar Autocompletado para el input de dirección
        const addressInput = document.getElementById('addressInput');
        // Prevenir envío del formulario al presionar Enter en el autocompletado
        addressInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
            }
        });

        const autocomplete = new google.maps.places.Autocomplete(addressInput);
        autocomplete.bindTo('bounds', map);

        autocomplete.addListener('place_changed', function() {
            const place = autocomplete.getPlace();
            if (!place.geometry || !place.geometry.location) {
                return;
            }
            
            map.setCenter(place.geometry.location);
            map.setZoom(16);
            marker.setPosition(place.geometry.location);
            updateCoordinates(place.geometry.location.lat(), place.geometry.location.lng());
        });
    }

    function updateCoordinates(lat, lng) {
        document.getElementById('latitude').value = lat;
        document.getElementById('longitude').value = lng;
    }

    function geocodePosition(pos) {
        geocoder.geocode({ location: pos }, function(results, status) {
            if (status === 'OK' && results[0]) {
                document.getElementById('addressInput').value = results[0].formatted_address;
            }
        });
    }

    // Validar antes de enviar el formulario real
    document.getElementById('formRegistroNegocio').addEventListener('submit', function(e) {
        if (!document.getElementById('latitude').value || !document.getElementById('longitude').value) {
            e.preventDefault(); // Evita que el form se envíe vacío
            alert('Por favor, selecciona una ubicación exacta en el mapa.');
        }
    });

    // Toggle de horarios de domingo
    document.getElementById('domingo_abierto')?.addEventListener('change', function() {
        document.getElementById('domingo_horarios').style.display = 'flex';
    });

    document.getElementById('domingo_cerrado')?.addEventListener('change', function() {
        document.getElementById('domingo_horarios').style.display = 'none';
    });

    // Ya no usamos DOMContentLoaded para initMap porque lo maneja el callback de Google Maps
</script>

