@{
    ViewData["Title"] = "Pago Pendiente - PIN Premium";
}

<div class="container py-5 text-center d-flex flex-column align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="card p-5 shadow-lg border-0 mx-auto" style="max-width: 550px; border-radius: 20px; background-color: #1a1a1a; color: white;">
        <div class="mb-4">
            <div class="mx-auto d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; border-radius: 50%; background-color: rgba(255, 193, 7, 0.2);">
                <i class="fas fa-clock text-warning" style="font-size: 3rem;"></i>
            </div>
        </div>
        
        <h2 class="fw-bold mb-3 text-warning">Pago Pendiente</h2>
        <p class="lead mb-4">
            Tu pago está siendo procesado por Mercado Pago. Esto puede tardar unos minutos si usaste métodos de pago en efectivo (agencias o banca por internet).
        </p>

        <hr style="border-color: #333;" class="my-4">

        <p class="text-white-50 small mb-4">
            Te notificaremos y activaremos tu membresía PIN Premium automáticamente tan pronto como el pago sea aprobado por la plataforma.
        </p>

        <div class="d-grid gap-2">
            <a href="/" class="btn btn-warning fw-bold py-3" style="background-color: var(--main-orange); color: white; border: none; border-radius: 30px;">Ir al Inicio</a>
            <a href="/Home/Beneficios" class="btn btn-outline-light py-3" style="border-radius: 30px;">Ver mis Estadísticas</a>
        </div>
    </div>
</div>
