@{
    ViewData["Title"] = "¡Pago Exitoso! - PIN Premium";
}

<div class="container py-5 text-center d-flex flex-column align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="card p-5 shadow-lg border-0 mx-auto" style="max-width: 550px; border-radius: 20px; background-color: #1a1a1a; color: white;">
        <div class="mb-4">
            <div class="mx-auto d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; border-radius: 50%; background-color: rgba(40, 167, 69, 0.2);">
                <i class="fas fa-check-circle text-success" style="font-size: 3rem;"></i>
            </div>
        </div>
        
        <h2 class="fw-bold mb-3" style="color: var(--main-orange);">¡Suscripción Activada!</h2>
        <p class="lead mb-4">
            Tu pago ha sido procesado exitosamente. Ahora eres un miembro **PIN Premium**.
        </p>

        <hr style="border-color: #333;" class="my-4">

        <div class="text-start mb-4">
            <h5 class="fw-bold mb-3"><i class="fas fa-star text-warning me-2"></i> Tus nuevos beneficios:</h5>
            <ul class="list-unstyled">
                <li class="mb-2"><i class="fas fa-chart-line text-orange me-2"></i> <strong>Estadísticas detalladas</strong> de visitas y clics de tus negocios.</li>
                <li class="mb-2"><i class="fas fa-arrow-up text-orange me-2"></i> <strong>Mayor visibilidad</strong> en las búsquedas locales.</li>
                <li class="mb-2"><i class="fas fa-certificate text-orange me-2"></i> Sello premium distintivo en tu perfil.</li>
            </ul>
        </div>

        <div class="d-grid gap-2">
            <a href="/" class="btn btn-warning fw-bold py-3" style="background-color: var(--main-orange); color: white; border: none; border-radius: 30px;">Ir al Inicio</a>
            <a href="/Home/Beneficios" class="btn btn-outline-light py-3" style="border-radius: 30px;">Ver mis Estadísticas</a>
        </div>
    </div>
</div>
