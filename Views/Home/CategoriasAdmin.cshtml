@{
    ViewData["Title"] = "Gestión de Categorías";
    Layout = "_Layout";
}
@model IEnumerable<PinAppdePromo.Models.Category>
@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/moderacion.css" asp-append-version="true" />
    <style>
        header, footer { display: none !important; }
        .admin-main-content {
            font-family: 'Outfit', sans-serif;
            background-color: #f8f9fa !important;
            background-image: radial-gradient(circle at top right, rgba(255,107,44,0.05), transparent 400px);
            min-height: 100vh;
        }
        @@media (min-width: 1024px) { .admin-main-content { margin-left: 18rem !important; } }
        .premium-header {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(229, 231, 235, 0.5);
            padding: 1.25rem 2rem; position: sticky; top: 0; z-index: 40;
        }
        .search-bar { background: #f1f5f9; border: 1px solid #e2e8f0; transition: all 0.3s ease; border-radius: 100px; }
        .search-bar:focus-within { background: white; border-color: #ff6b2c; box-shadow: 0 0 0 4px rgba(255,107,44,0.15); }
    </style>
}

<div class='min-h-screen text-slate-900'>
    <div class='lg:flex lg:min-h-screen'>
        <!-- Inyectamos el Sidebar modular -->
        <partial name="_ModeracionSidebar" />
        
        <main class='flex-1 admin-main-content'>
            <!-- Header -->
            <div class='premium-header'>
                <div class='flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between w-full'>
                    <form method="get" action="/Home/NegociosAdmin" class='search-bar flex w-full max-w-md items-center gap-3 px-5 py-2.5 m-0'>
                        <i class='fas fa-search text-slate-400'></i>
                        <input type='search' name='busqueda' placeholder='Buscar negocio, usuario o reporte...' class='w-full bg-transparent text-sm font-medium text-slate-700 outline-none placeholder-slate-400' />
                    </form>
                    <div class='flex flex-wrap items-center gap-4 text-sm'>
                        <a href='/' class='font-bold text-white transition-transform hover:scale-105 flex items-center gap-2 px-4 py-2 rounded-full shadow-sm' style="background: linear-gradient(135deg, #ff6b2c, #ff8a50);">
                            <i class='fas fa-arrow-left'></i> Volver a la App
                        </a>
                        
                        <!-- Perfil Dropdown -->
                        <div class="dropdown">
                            <button class='flex items-center gap-3 rounded-full bg-white px-2 py-1.5 shadow-sm border border-slate-200 pr-4 cursor-pointer transition hover:border-[#ff6b2c]' data-bs-toggle="dropdown" aria-expanded="false" style="outline: none;">
                                @{
                                    var adminName = Context.Session.GetString("Nombre") ?? "Admin";
                                    var adminInitials = adminName.Length >= 2 ? adminName.Substring(0, 2).ToUpper() : "AD";
                                    var adminFoto = Context.Session.GetString("Foto");
                                }
                                @if (!string.IsNullOrEmpty(adminFoto))
                                {
                                    <img src="@adminFoto" alt="Perfil" class="h-9 w-9 rounded-full object-cover shadow-sm border border-slate-100" referrerpolicy="no-referrer" />
                                }
                                else
                                {
                                    <span class='inline-flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-[#ff6b2c] to-[#ff8a50] text-white font-bold shadow-sm'>@adminInitials</span>
                                }
                                <div class="text-left hidden sm:block">
                                    <p class='font-bold text-slate-900 leading-tight'>@adminName</p>
                                    <p class='text-[10px] uppercase tracking-wider font-bold text-[#ff6b2c] mt-0.5'>Moderador</p>
                                </div>
                                <i class="fas fa-chevron-down text-slate-400 ml-1 text-xs hidden sm:block"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2 py-2" style="min-width: 200px; box-shadow: 0 10px 40px -10px rgba(0,0,0,0.1);">
                                <li>
                                    <div class="px-4 py-2 border-b border-slate-100 mb-2">
                                        <p class="text-sm font-bold text-slate-900 truncate">Hola, @adminName</p>
                                        <p class="text-xs text-slate-500 truncate">@Context.Session.GetString("Usuario")</p>
                                    </div>
                                </li>
                                <li><a class="dropdown-item py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:text-[#ff6b2c]" href="/Home/Perfil"><i class="fas fa-user w-5 text-slate-400 text-center"></i> Mi Perfil</a></li>
                                <li><hr class="dropdown-divider border-slate-100 my-2"></li>
                                <li><a class="dropdown-item py-2 text-sm font-bold text-red-600 hover:bg-red-50" href="/Login/Logout"><i class="fas fa-sign-out-alt w-5 text-center"></i> Cerrar Sesión</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <section class='p-8 max-w-7xl mx-auto'>
                <div class="mb-8">
                    <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Gestión de Categorías</h1>
                    <p class="text-slate-500 mt-2 text-lg">Organiza y administra las categorías de los establecimientos.</p>
                </div>
                <!-- TOOLBAR: BÚSQUEDA Y CREACIÓN -->
                <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-4 mb-6">
                    <!-- Barra de Búsqueda de Categorías -->
                    <form method="get" asp-action="CategoriasAdmin" class="flex w-full lg:max-w-md items-center gap-3 bg-white border border-slate-200 rounded-xl px-4 py-2.5 focus-within:border-[#ff6b2c] focus-within:ring-1 focus-within:ring-[#ff6b2c] transition shadow-sm">
                        <i class="fas fa-search text-slate-400"></i>
                        <input type="text" name="busqueda" value="@ViewBag.Busqueda" placeholder="Buscar categoría en esta lista..." class="w-full bg-transparent outline-none text-sm text-slate-700 placeholder-slate-400" />
                    </form>

                    <!-- Formulario Rápido de Creación -->
                    <form asp-action="CrearCategoria" asp-controller="Home" method="post" class="flex w-full lg:w-auto gap-3">
                        <div class="relative flex-1 lg:w-64">
                            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4">
                                <i class="fas fa-tag text-slate-400"></i>
                            </div>
                            <input type="text" name="Name" placeholder="Nombre de nueva categoría..." required class="block w-full rounded-xl border border-slate-200 bg-white shadow-sm py-2.5 pl-11 pr-4 text-sm font-medium text-slate-700 outline-none transition focus:border-[#a04028] focus:ring-1 focus:ring-[#a04028] placeholder-slate-400" />
                        </div>
                        <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-[#2b2b2b] px-5 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-black focus:outline-none focus:ring-2 focus:ring-black focus:ring-offset-2">
                            <i class="fas fa-plus mr-2"></i>Crear
                        </button>
                    </form>
                </div>

                <div class='admin-card overflow-hidden rounded-2xl shadow-sm'>
                    <div class="border-b border-slate-200 bg-slate-50/50 px-6 py-4">
                        <h3 class="font-semibold text-slate-800">Categorías Existentes</h3>
                    </div>
                    <div class="overflow-x-auto">
                    <table class='admin-table min-w-full divide-y divide-slate-200 text-left text-sm'>
                        <thead class='bg-slate-50 text-slate-500'>
                            <tr>
                                <th scope="col" class='px-6 py-4 font-medium uppercase tracking-wider text-xs'>ID</th>
                                <th scope="col" class='px-6 py-4 font-medium uppercase tracking-wider text-xs'>Nombre de la Categoría</th>
                                <th scope="col" class='px-6 py-4 font-medium uppercase tracking-wider text-xs text-right'>Acciones</th>
                            </tr>
                        </thead>
                        <tbody class='divide-y divide-slate-100 bg-white'>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var categoria in Model)
                                {
                                    <tr>
                                        <td class='whitespace-nowrap px-6 py-5 text-slate-400 font-mono text-xs'>
                                            #@categoria.CategoryId.ToString("D4")
                                        </td>
                                        <td class='px-6 py-5 w-full'>
                                            <!-- ESTADO DE LECTURA (TEXTO) -->
                                            <div id="view-mode-@categoria.CategoryId" class="flex items-center">
                                                <div class="h-8 w-8 rounded-lg bg-[#f3e5df] text-[#a04028] flex items-center justify-center mr-3">
                                                    <i class="fas fa-folder"></i>
                                                </div>
                                                <span class="font-semibold text-slate-700 text-base">@categoria.Name</span>
                                            </div>
                                            <!-- ESTADO DE EDICIÓN (OCULTO POR DEFECTO) -->
                                            <form id="edit-mode-@categoria.CategoryId" asp-action="EditarCategoria" asp-controller="Home" method="post" class="hidden items-center gap-2">
                                                <input type="hidden" name="CategoryId" value="@categoria.CategoryId" />
                                                <div class="h-8 w-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center mr-1">
                                                    <i class="fas fa-pen"></i>
                                                </div>
                                                <input type="text" name="Name" value="@categoria.Name" required class="block w-full max-w-sm rounded-lg border border-blue-300 bg-white py-1.5 px-3 text-sm outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 shadow-sm" />
                                                <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-xs font-medium text-emerald-700 shadow-sm transition hover:bg-emerald-600 hover:text-white">
                                                    <i class="fas fa-save"></i> Guardar
                                                </button>
                                                <button type="button" onclick="toggleEdit(@categoria.CategoryId, false)" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-700 shadow-sm transition hover:bg-slate-50">
                                                    <i class="fas fa-times"></i> Cancelar
                                                </button>
                                            </form>
                                        </td>
                                        <td class='whitespace-nowrap px-6 py-5 text-right'>
                                            <div id="actions-@categoria.CategoryId" class="flex items-center justify-end gap-2 flex-wrap">
                                                <!-- BOTÓN DE EDITAR -->
                                                <button type="button" onclick="toggleEdit(@categoria.CategoryId, true)" class='inline-flex items-center gap-1.5 rounded-lg border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-medium text-blue-700 shadow-sm transition hover:bg-blue-600 hover:text-white'>
                                                    <i class='fas fa-pen'></i> Editar
                                                </button>
                                                <!-- BOTÓN DE ELIMINAR -->
                                                <form asp-action="EliminarCategoria" asp-controller="Home" method="post" onsubmit="return confirm('¿Seguro que deseas eliminar esta categoría? Si tiene negocios asociados podría ocultarlos del panel de explorar.');" class="inline m-0">
                                                    <input type="hidden" name="CategoryId" value="@categoria.CategoryId" />
                                                    <button type="submit" class='inline-flex items-center gap-1.5 rounded-lg border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-medium text-red-600 shadow-sm transition hover:bg-red-600 hover:text-white'>
                                                        <i class='fas fa-trash-alt'></i> Eliminar
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <!-- EMPTY STATE REDISEÑADO -->
                                <tr>
                                    <td colspan="3" class="px-6 py-16 text-center">
                                        <div class="flex flex-col items-center justify-center">
                                            <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-slate-100 text-slate-400">
                                                <i class="fas fa-folder-open text-2xl"></i>
                                            </div>
                                            <h3 class="text-base font-semibold text-slate-900">No hay categorías</h3>
                                            <p class="mt-1 text-sm text-slate-500">Empieza creando tu primera categoría para clasificar los negocios.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                    <!-- PAGINACIÓN -->
                    @if (ViewBag.TotalCategorias > 0)
                    {
                        <div class='border-t border-slate-200 bg-slate-50/50 p-4 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between'>
                            <p class='text-sm text-slate-500 font-medium'>Mostrando @Model.Count() de @ViewBag.TotalCategorias categorías</p>
                            <div class='flex flex-wrap items-center justify-center gap-2'>
                                @if (ViewBag.PaginaActual > 1) {
                                    <a href="?busqueda=@ViewBag.Busqueda&pagina=@(ViewBag.PaginaActual - 1)" class='rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-600 shadow-sm transition hover:bg-slate-50'>Anterior</a>
                                }
                                
                                @{
                                    int totalPages = ViewBag.TotalPaginas;
                                    int currentPage = ViewBag.PaginaActual;
                                    int maxPagesToShow = 5;
                                    int startPage = Math.Max(1, currentPage - maxPagesToShow / 2);
                                    int endPage = Math.Min(totalPages, startPage + maxPagesToShow - 1);

                                    if (endPage - startPage + 1 < maxPagesToShow)
                                    {
                                        startPage = Math.Max(1, endPage - maxPagesToShow + 1);
                                    }
                                }

                                @if (startPage > 1)
                                {
                                    <a href="?busqueda=@ViewBag.Busqueda&pagina=1" class='rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 px-3 py-1.5 text-sm font-medium shadow-sm transition'>1</a>
                                    @if (startPage > 2)
                                    {
                                        <span class='px-2 text-slate-400'>...</span>
                                    }
                                }

                                @for (int i = startPage; i <= endPage; i++) {
                                    <a href="?busqueda=@ViewBag.Busqueda&pagina=@i" class='rounded-lg border px-3 py-1.5 text-sm font-medium shadow-sm transition @(i == ViewBag.PaginaActual ? "" : "border-slate-300 bg-white text-slate-600 hover:bg-slate-50")' @(i == ViewBag.PaginaActual ? "style=background-color:#ff6b2c;border-color:#ff6b2c;color:white;" : "")>@i</a>
                                }

                                @if (endPage < totalPages)
                                {
                                    @if (endPage < totalPages - 1)
                                    {
                                        <span class='px-2 text-slate-400'>...</span>
                                    }
                                    <a href="?busqueda=@ViewBag.Busqueda&pagina=@totalPages" class='rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 px-3 py-1.5 text-sm font-medium shadow-sm transition'>@totalPages</a>
                                }

                                @if (ViewBag.PaginaActual < ViewBag.TotalPaginas) {
                                    <a href="?busqueda=@ViewBag.Busqueda&pagina=@(ViewBag.PaginaActual + 1)" class='rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-600 shadow-sm transition hover:bg-slate-50'>Siguiente</a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>
        </main>
    </div>
</div>

@section Scripts {
    <script>
        // Script para cambiar entre el modo visualización y modo edición
        function toggleEdit(id, showEdit) {
            const viewMode = document.getElementById('view-mode-' + id);
            const editMode = document.getElementById('edit-mode-' + id);
            const actions = document.getElementById('actions-' + id);
            
            if (showEdit) {
                viewMode.classList.add('hidden');
                actions.classList.add('hidden');
                editMode.classList.remove('hidden');
                editMode.classList.add('flex');
                
                const input = editMode.querySelector('input[type="text"]');
                if(input) {
                    input.focus();
                    const val = input.value;
                    input.value = '';
                    input.value = val;
                }
            } else {
                editMode.classList.add('hidden');
                editMode.classList.remove('flex');
                viewMode.classList.remove('hidden');
                actions.classList.remove('hidden');
            }
        }
    </script>
}