@{
    ViewData["Title"] = "Gestión de Negocios";
    Layout = "_Layout";
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
}
@model IEnumerable<PinAppdePromo.Models.Business>
@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/moderacion.css" asp-append-version="true" />
    <style>
        header, footer { display: none !important; }
        .admin-main-content {
            font-family: 'Outfit', sans-serif;
            background-color: #f8f9fa !important;
            background-image: radial-gradient(circle at top right, rgba(255,107,44,0.05), transparent 400px);
            min-height: 100vh;
        }
        @@media (min-width: 1024px) { .admin-main-content { margin-left: 18rem !important; } }
        .premium-header {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(229, 231, 235, 0.5);
            padding: 1.25rem 2rem; position: sticky; top: 0; z-index: 40;
        }
        .search-bar { background: #f1f5f9; border: 1px solid #e2e8f0; transition: all 0.3s ease; border-radius: 100px; }
        .search-bar:focus-within { background: white; border-color: #ff6b2c; box-shadow: 0 0 0 4px rgba(255,107,44,0.15); }
    </style>
}

<div class='min-h-screen text-slate-900'>
    <div class='lg:flex lg:min-h-screen'>
        <!-- Inyectamos el Sidebar modular -->
        <partial name="_ModeracionSidebar" />
        
        <main class='flex-1 admin-main-content'>
            <!-- Header -->
            <div class='premium-header'>
                <div class='flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between w-full'>
                    <form method="get" action="/Home/NegociosAdmin" class='search-bar flex w-full max-w-md items-center gap-3 px-5 py-2.5 m-0'>
                        <i class='fas fa-search text-slate-400'></i>
                        <input type='search' name='busqueda' placeholder='Buscar negocio, usuario o reporte...' class='w-full bg-transparent text-sm font-medium text-slate-700 outline-none placeholder-slate-400' />
                    </form>
                    <div class='flex flex-wrap items-center gap-4 text-sm'>
                        <a href='/' class='font-bold text-white transition-transform hover:scale-105 flex items-center gap-2 px-4 py-2 rounded-full shadow-sm' style="background: linear-gradient(135deg, #ff6b2c, #ff8a50);">
                            <i class='fas fa-arrow-left'></i> Volver a la App
                        </a>
                        <a href='#' class='font-semibold text-slate-500 hover:text-[#ff6b2c] transition-colors hidden sm:block'>Documentación</a>
                        
                        <!-- Perfil Dropdown -->
                        <div class="dropdown">
                            <button class='flex items-center gap-3 rounded-full bg-white px-2 py-1.5 shadow-sm border border-slate-200 pr-4 cursor-pointer transition hover:border-[#ff6b2c]' data-bs-toggle="dropdown" aria-expanded="false" style="outline: none;">
                                @{
                                    var adminName = Context.Session.GetString("Nombre") ?? "Admin";
                                    var adminInitials = adminName.Length >= 2 ? adminName.Substring(0, 2).ToUpper() : "AD";
                                    var fotoPerfil = Context.Session.GetString("Foto");
                                }
                                @if (!string.IsNullOrEmpty(fotoPerfil))
                                {
                                    <img src="@fotoPerfil" alt="Perfil" class="h-9 w-9 rounded-full object-cover shadow-sm border border-slate-100" referrerpolicy="no-referrer" />
                                }
                                else
                                {
                                    <span class='inline-flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-[#ff6b2c] to-[#ff8a50] text-white font-bold shadow-sm'>@adminInitials</span>
                                }
                                <div class="text-left hidden sm:block">
                                    <p class='font-bold text-slate-900 leading-tight'>@adminName</p>
                                    <p class='text-[10px] uppercase tracking-wider font-bold text-[#ff6b2c] mt-0.5'>Moderador</p>
                                </div>
                                <i class="fas fa-chevron-down text-slate-400 ml-1 text-xs hidden sm:block"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2 py-2" style="min-width: 200px; box-shadow: 0 10px 40px -10px rgba(0,0,0,0.1);">
                                <li>
                                    <div class="px-4 py-2 border-b border-slate-100 mb-2">
                                        <p class="text-sm font-bold text-slate-900 truncate">Hola, @adminName</p>
                                        <p class="text-xs text-slate-500 truncate">@Context.Session.GetString("Usuario")</p>
                                    </div>
                                </li>
                                <li><a class="dropdown-item py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:text-[#ff6b2c]" href="/Home/Perfil"><i class="fas fa-user w-5 text-slate-400 text-center"></i> Mi Perfil</a></li>
                                <li><hr class="dropdown-divider border-slate-100 my-2"></li>
                                <li><a class="dropdown-item py-2 text-sm font-bold text-red-600 hover:bg-red-50" href="/Login/Logout"><i class="fas fa-sign-out-alt w-5 text-center"></i> Cerrar Sesión</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <section class='p-8 max-w-7xl mx-auto'>
                <div class="mb-8">
                    <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Gestión de Negocios</h1>
                    <p class="text-slate-500 mt-2 text-lg">Supervisa, aprueba y administra los establecimientos registrados en la plataforma.</p>
                </div>
                
                @if (TempData["ExitoEdicion"] != null)
                {
                    <div class="mb-6 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl flex items-center gap-3">
                        <i class="fas fa-check-circle text-emerald-500"></i>
                        <p class="text-sm font-medium">@TempData["ExitoEdicion"]</p>
                    </div>
                }

                <!-- BARRA DE BÚSQUEDA Y FILTROS -->
                <form method="get" asp-action="NegociosAdmin" class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between bg-white p-4 rounded-2xl shadow-sm border border-slate-200">
                    <div class="flex flex-1 items-center gap-3 w-full sm:max-w-md border border-slate-300 rounded-xl px-4 py-2 focus-within:border-[#ff6b00] focus-within:ring-1 focus-within:ring-[#ff6b00] transition bg-slate-50">
                        <i class="fas fa-search text-slate-400"></i>
                        <input type="text" name="busqueda" value="@ViewBag.Busqueda" placeholder="Buscar por nombre de negocio o dirección..." class="w-full bg-transparent outline-none text-sm" />
                    </div>
                    <div class="flex items-center gap-3 w-full sm:w-auto">
                        <select name="filtroEstado" class="w-full sm:w-auto border border-slate-300 rounded-xl px-4 py-2 text-sm font-medium text-slate-700 outline-none focus:border-[#ff6b2c] bg-white shadow-sm cursor-pointer" onchange="this.form.submit()">
                            <option value="TODOS">Todos los estados</option>
                            <option value="Pending" selected="@(ViewBag.FiltroEstado == "Pending")">Pendientes de Aprobación</option>
                            <option value="Approved" selected="@(ViewBag.FiltroEstado == "Approved")">Aprobados / Activos</option>
                            <option value="Promoted" selected="@(ViewBag.FiltroEstado == "Promoted")">Promocionados</option>
                            <option value="Rejected" selected="@(ViewBag.FiltroEstado == "Rejected")">Rechazados / Suspendidos</option>
                        </select>
                    </div>
                </form>

                <div class='admin-card overflow-hidden rounded-2xl shadow-sm'>
                    <div class="overflow-x-auto">
                        <table class='admin-table min-w-full divide-y divide-slate-200 text-left text-sm'>
                            <thead class='bg-slate-50 text-slate-500'>
                                <tr>
                                    <th scope="col" class='px-6 py-4 font-medium uppercase tracking-wider text-xs'>Negocio</th>
                                    <th scope="col" class='px-6 py-4 font-medium uppercase tracking-wider text-xs'>Ubicación</th>
                                    <th scope="col" class='px-6 py-4 font-medium uppercase tracking-wider text-xs'>Estado</th>
                                    <th scope="col" class='px-6 py-4 font-medium uppercase tracking-wider text-xs text-right'>Acciones</th>
                                </tr>
                            </thead>
                            <tbody class='divide-y divide-slate-100 bg-white'>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var negocio in Model)
                                    {
                                        <tr>
                                            <td class='px-6 py-4'>
                                                <div class="flex flex-col gap-1 items-start">
                                                    <p class="font-semibold text-slate-900 text-base">@negocio.TradeName</p>
                                                    <span class='inline-flex rounded-full bg-slate-100 px-2.5 py-0.5 text-[10px] font-semibold text-slate-600 border border-slate-200'>
                                                        @(negocio.Category?.Name ?? "General")
                                                    </span>
                                                </div>
                                            </td>
                                            <td class='px-6 py-4'>
                                                <div class="flex items-center gap-2 text-slate-600">
                                                    <i class="fas fa-map-marker-alt text-slate-400"></i>
                                                    <span class="truncate max-w-[200px]">@negocio.Address</span>
                                                </div>
                                            </td>
                                            <td class='px-6 py-4'>
                                                @if (negocio.Status == "Approved" || negocio.Status == "Promoted")
                                                {
                                                    <span class='inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 border border-emerald-200'>
                                                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> Activo
                                                    </span>
                                                }
                                                else if (negocio.Status == "Pending")
                                                {
                                                    <span class='inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700 border border-amber-200'>
                                                        <span class="h-1.5 w-1.5 rounded-full bg-amber-500"></span> Pendiente
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class='inline-flex items-center gap-1.5 rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-700 border border-red-200'>
                                                        <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span> Rechazado
                                                    </span>
                                                }
                                            </td>
                                            <td class='px-6 py-4 text-right'>
                                                <div class="flex items-center justify-end gap-2 flex-wrap">
                                                    <a href="/Home/EditarNegocioModerador/@negocio.BusinessId" class='inline-flex items-center gap-1.5 rounded-lg border border-blue-200 bg-blue-50 px-3 py-1.5 text-xs font-medium text-blue-700 shadow-sm transition hover:bg-blue-600 hover:text-white'>
                                                        <i class='fas fa-edit'></i> Editar
                                                    </a>
                                                    @if (negocio.Status != "Approved" && negocio.Status != "Promoted")
                                                    {
                                                        <form asp-action="CambiarEstadoNegocio" asp-controller="Home" method="post" class="m-0 inline" onsubmit="return confirm('¿Aprobar este negocio? Será visible públicamente.');">
                                                            <input type="hidden" name="businessId" value="@negocio.BusinessId" />
                                                            <input type="hidden" name="nuevoEstado" value="Approved" />
                                                            <input type="hidden" name="returnUrl" value="@currentUrl" />
                                                            <button type="submit" class='inline-flex items-center gap-1.5 rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-xs font-medium text-emerald-700 shadow-sm transition hover:bg-emerald-600 hover:text-white'>
                                                                <i class='fas fa-check'></i> Aprobar
                                                            </button>
                                                        </form>
                                                    }
                                                    @if (negocio.Status != "Rejected")
                                                    {
                                                        <form asp-action="CambiarEstadoNegocio" asp-controller="Home" method="post" class="m-0 inline" onsubmit="return confirm('¿Rechazar o suspender este negocio? Dejará de ser visible públicamente.');">
                                                            <input type="hidden" name="businessId" value="@negocio.BusinessId" />
                                                            <input type="hidden" name="nuevoEstado" value="Rejected" />
                                                            <input type="hidden" name="returnUrl" value="@currentUrl" />
                                                            <button type="submit" class='inline-flex items-center gap-1.5 rounded-lg border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-medium text-red-600 shadow-sm transition hover:bg-red-600 hover:text-white'>
                                                                <i class='fas fa-ban'></i> Suspender
                                                            </button>
                                                        </form>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="px-6 py-12 text-center">
                                            <div class="flex flex-col items-center justify-center">
                                                <i class="fas fa-store-slash text-4xl text-slate-300 mb-3"></i>
                                                <p class="text-base font-semibold text-slate-900">No hay negocios que coincidan</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- PAGINACIÓN -->
                    @if (ViewBag.TotalNegocios > 0)
                    {
                        <div class='border-t border-slate-200 bg-slate-50/50 p-4 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between'>
                            <p class='text-sm text-slate-500 font-medium'>Mostrando @Model.Count() de @ViewBag.TotalNegocios negocios</p>
                            <div class='flex flex-wrap items-center justify-center gap-2'>
                                @if (ViewBag.PaginaActual > 1) {
                                    <a href="?busqueda=@ViewBag.Busqueda&filtroEstado=@ViewBag.FiltroEstado&pagina=@(ViewBag.PaginaActual - 1)" class='rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-600 shadow-sm transition hover:bg-slate-50'>Anterior</a>
                                }
                                
                                @{
                                    int totalPages = ViewBag.TotalPaginas;
                                    int currentPage = ViewBag.PaginaActual;
                                    int maxPagesToShow = 5;
                                    int startPage = Math.Max(1, currentPage - maxPagesToShow / 2);
                                    int endPage = Math.Min(totalPages, startPage + maxPagesToShow - 1);

                                    if (endPage - startPage + 1 < maxPagesToShow)
                                    {
                                        startPage = Math.Max(1, endPage - maxPagesToShow + 1);
                                    }
                                }

                                @if (startPage > 1)
                                {
                                    <a href="?busqueda=@ViewBag.Busqueda&filtroEstado=@ViewBag.FiltroEstado&pagina=1" class='rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 px-3 py-1.5 text-sm font-medium shadow-sm transition'>1</a>
                                    @if (startPage > 2)
                                    {
                                        <span class='px-2 text-slate-400'>...</span>
                                    }
                                }

                                @for (int i = startPage; i <= endPage; i++) {
                                    <a href="?busqueda=@ViewBag.Busqueda&filtroEstado=@ViewBag.FiltroEstado&pagina=@i" class='rounded-lg border px-3 py-1.5 text-sm font-medium shadow-sm transition @(i == ViewBag.PaginaActual ? "" : "border-slate-300 bg-white text-slate-600 hover:bg-slate-50")' @(i == ViewBag.PaginaActual ? "style=background-color:#ff6b2c;border-color:#ff6b2c;color:white;" : "")>@i</a>
                                }

                                @if (endPage < totalPages)
                                {
                                    @if (endPage < totalPages - 1)
                                    {
                                        <span class='px-2 text-slate-400'>...</span>
                                    }
                                    <a href="?busqueda=@ViewBag.Busqueda&filtroEstado=@ViewBag.FiltroEstado&pagina=@totalPages" class='rounded-lg border border-slate-300 bg-white text-slate-600 hover:bg-slate-50 px-3 py-1.5 text-sm font-medium shadow-sm transition'>@totalPages</a>
                                }

                                @if (ViewBag.PaginaActual < ViewBag.TotalPaginas) {
                                    <a href="?busqueda=@ViewBag.Busqueda&filtroEstado=@ViewBag.FiltroEstado&pagina=@(ViewBag.PaginaActual + 1)" class='rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-600 shadow-sm transition hover:bg-slate-50'>Siguiente</a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>
        </main>
    </div>
</div>