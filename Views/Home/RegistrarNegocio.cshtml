@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Registrar Negocio - Pin";
    var googleMapsApiKey = Configuration["GoogleMaps:ApiKey"];
    bool hasValidGoogleMaps = !string.IsNullOrEmpty(googleMapsApiKey) && 
                              !googleMapsApiKey.Contains("TU_API_KEY") && 
                              !googleMapsApiKey.Contains("LOCAL") &&
                              !googleMapsApiKey.Contains("AQUI");
}
@model PinAppdePromo.Models.Business

@section Styles {
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    @if (!hasValidGoogleMaps)
    {
        <!-- Leaflet CSS -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
        <!-- Leaflet Geocoder CSS -->
        <link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css" />
    }
    <style>
        body {
            background-color: #f8f9fa;
        }

        .text-orange { color: #ff6b2c; }

        .register-header {
            background: linear-gradient(135deg, #ff6b2c 0%, #ff8a50 100%);
            padding: 4rem 0;
            color: white;
            text-align: center;
            margin-bottom: 3rem;
            position: relative;
            overflow: hidden;
            border-radius: 0 0 40px 40px;
            box-shadow: 0 10px 30px rgba(255, 107, 44, 0.2);
        }

        .register-header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -10%;
            width: 400px;
            height: 400px;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 50%;
        }

        .register-header::after {
            content: '';
            position: absolute;
            bottom: -50%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border-radius: 50%;
        }

        .register-header h1 {
            font-family: 'Outfit', sans-serif;
            font-weight: 800;
            font-size: 3rem;
            position: relative;
            z-index: 2;
        }

        .register-header p {
            font-size: 1.2rem;
            opacity: 0.9;
            position: relative;
            z-index: 2;
            max-width: 600px;
            margin: 0 auto;
        }

        .premium-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.04);
            margin-bottom: 2.5rem;
            background: #ffffff;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            overflow: hidden;
        }

        .premium-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }

        .card-header-custom {
            background: transparent;
            border-bottom: 1px solid #f0f0f0;
            padding: 1.5rem 2rem;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .card-header-custom h3 {
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            color: #2b2b2b;
            margin: 0;
            font-size: 1.5rem;
        }

        .icon-circle {
            width: 45px;
            height: 45px;
            background: #fff2eb;
            color: #ff6b2c;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .card-body-custom {
            padding: 2.5rem;
        }

        .form-label {
            font-weight: 600;
            color: #4a5568;
            margin-bottom: 0.5rem;
        }

        .form-control, .form-select {
            padding: 0.8rem 1.2rem;
            border-radius: 12px;
            border: 2px solid #e2e8f0;
            background-color: #f8fafc;
            transition: all 0.3s ease;
            font-family: 'Outfit', sans-serif;
        }

        .form-control:focus, .form-select:focus {
            border-color: #ff6b2c;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(255, 107, 44, 0.1);
        }

        .map-container {
            border-radius: 16px;
            overflow: hidden;
            border: 2px solid #e2e8f0;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
        }

        #map {
            height: 400px;
            width: 100%;
        }

        .drag-drop-zone {
            border: 2px dashed #cbd5e1;
            border-radius: 16px;
            background-color: #f8fafc;
            padding: 3rem 2rem;
            text-align: center;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .drag-drop-zone:hover {
            border-color: #ff6b2c;
            background-color: #fff2eb;
        }

        .drag-drop-icon {
            font-size: 3rem;
            color: #ff6b2c;
            margin-bottom: 1rem;
        }

        .time-input-group {
            display: flex;
            align-items: center;
            gap: 15px;
            background: #f8fafc;
            padding: 1rem;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
        }

        .time-input-group span {
            color: #64748b;
            font-weight: 500;
        }

        .btn-submit-premium {
            background: linear-gradient(135deg, #ff6b2c 0%, #e85a1f 100%);
            color: white;
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
            font-size: 1.2rem;
            padding: 1.2rem;
            border-radius: 16px;
            border: none;
            width: 100%;
            transition: all 0.3s ease;
            box-shadow: 0 10px 25px rgba(255, 107, 44, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-submit-premium:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(255, 107, 44, 0.4);
            color: white;
        }

        .form-check-input:checked {
            background-color: #ff6b2c;
            border-color: #ff6b2c;
        }
    </style>
}

<div class="register-header">
    <div class="container">
        <h1 class="mb-3">Registra tu negocio en PIN</h1>
        <p>Llega a miles de clientes locales y haz crecer tus ventas hoy mismo. Completar este formulario te tomará menos de 5 minutos.</p>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-4 mb-4 shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="CrearNegocio" asp-controller="Home" method="post" enctype="multipart/form-data" id="formRegistroNegocio">
                
                <!-- 1. Información Básica -->
                <div class="premium-card">
                    <div class="card-header-custom">
                        <div class="icon-circle"><i class="bi bi-shop"></i></div>
                        <h3>1. Información Básica</h3>
                    </div>
                    <div class="card-body-custom row g-4">
                        <div class="col-md-6">
                            <label class="form-label">Nombre del Negocio *</label>
                            <input type="text" class="form-control" name="TradeName" placeholder="Ej. El Bodegón del Sur" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Categoría *</label>
                            <select class="form-select" name="CategoryId">
                                @if (ViewBag.Categorias != null)
                                {
                                    foreach (var cat in ViewBag.Categorias)
                                    {
                                        <option value="@cat.CategoryId">@cat.Name</option>
                                    }
                                }
                                else
                                {
                                    <option value="1">General</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Descripción corta *</label>
                            <textarea class="form-control" name="Description" rows="3" placeholder="Cuéntanos qué hace especial a tu negocio..." required></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">RUC (Opcional)</label>
                            <input type="text" class="form-control" name="RUC" placeholder="Ej. 20512345678" maxlength="11">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Teléfono de contacto *</label>
                            <input type="tel" class="form-control" name="ContactPhone" placeholder="Ej. 987654321" required>
                        </div>
                    </div>
                </div>

                <!-- 2. Ubicación -->
                <div class="premium-card">
                    <div class="card-header-custom">
                        <div class="icon-circle"><i class="bi bi-geo-alt-fill"></i></div>
                        <h3>2. ¿Dónde estás ubicado?</h3>
                    </div>
                    <div class="card-body-custom">
                        <div class="mb-4">
                            <label class="form-label">Dirección exacta *</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 rounded-start-4"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" class="form-control border-start-0 rounded-end-4 ps-0" id="addressInput" name="Address" placeholder="Busca tu calle, avenida o distrito..." required>
                            </div>
                            <small class="text-muted mt-2 d-block"><i class="bi bi-info-circle me-1"></i> También puedes arrastrar el marcador rojo en el mapa para ajustar la ubicación exacta.</small>
                        </div>
                        <div class="map-container">
                            <div id="map"></div>
                        </div>
                        <input type="hidden" id="latitude" name="Latitude" />
                        <input type="hidden" id="longitude" name="Longitude" />
                    </div>
                </div>

                <!-- 3. Imágenes -->
                <div class="premium-card">
                    <div class="card-header-custom">
                        <div class="icon-circle"><i class="bi bi-images"></i></div>
                        <h3>3. Atrae con fotos</h3>
                    </div>
                    <div class="card-body-custom">
                        <div class="row g-4">
                            <div class="col-12">
                                <label class="form-label">Opción 1: Usa una foto de internet (Recomendado para rapidez)</label>
                                <input type="url" class="form-control" name="ImageUrlLink" placeholder="Pega aquí el enlace de tu foto (Ej. https://misitio.com/foto.jpg)">
                            </div>
                            
                            <div class="col-12 text-center position-relative my-2">
                                <hr class="text-muted">
                                <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted fw-bold">O TAMBIÉN</span>
                            </div>
                            
                            <div class="col-12">
                                <label class="form-label">Opción 2: Sube tus propias fotos</label>
                                <div class="drag-drop-zone position-relative">
                                    <div class="drag-drop-icon"><i class="bi bi-cloud-arrow-up-fill"></i></div>
                                    <h5 class="fw-bold mb-1">Haz clic o arrastra fotos aquí</h5>
                                    <p class="text-muted mb-0 small">Máximo 10MB por archivo (Formatos: JPG, PNG)</p>
                                    <!-- Input file invisible que cubre toda la zona -->
                                    <input type="file" name="Imagenes" multiple class="position-absolute top-0 start-0 w-100 h-100" style="opacity: 0; cursor: pointer;" accept="image/*" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 4. Horarios -->
                <div class="premium-card">
                    <div class="card-header-custom">
                        <div class="icon-circle"><i class="bi bi-clock-fill"></i></div>
                        <h3>4. Horarios de Atención</h3>
                    </div>
                    <div class="card-body-custom row g-4">
                        <!-- Lunes a Viernes -->
                        <div class="col-md-6">
                            <label class="form-label text-orange"><i class="bi bi-calendar2-week me-2"></i>LUNES A VIERNES</label>
                            <div class="time-input-group">
                                <input type="time" class="form-control border-0 bg-transparent p-0 shadow-none" id="lv_inicio" value="09:00">
                                <span>a</span>
                                <input type="time" class="form-control border-0 bg-transparent p-0 shadow-none" id="lv_fin" value="18:00">
                            </div>
                        </div>

                        <!-- Sábados -->
                        <div class="col-md-6">
                            <label class="form-label text-orange"><i class="bi bi-calendar2-event me-2"></i>SÁBADOS</label>
                            <div class="time-input-group">
                                <input type="time" class="form-control border-0 bg-transparent p-0 shadow-none" id="s_inicio" value="10:00">
                                <span>a</span>
                                <input type="time" class="form-control border-0 bg-transparent p-0 shadow-none" id="s_fin" value="14:00">
                            </div>
                        </div>

                        <!-- Domingos -->
                        <div class="col-12 mt-4">
                            <label class="form-label text-orange"><i class="bi bi-calendar2-x me-2"></i>DOMINGOS Y FERIADOS</label>
                            <div class="d-flex flex-wrap gap-4 mt-2">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="domingo" id="domingo_cerrado" checked>
                                    <label class="form-check-label fw-medium" for="domingo_cerrado">Cerrado</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="domingo" id="domingo_abierto">
                                    <label class="form-check-label fw-medium" for="domingo_abierto">Abierto</label>
                                </div>
                            </div>
                            <div class="time-input-group mt-3" id="domingo_horarios" style="display:none; max-width: 50%;">
                                <input type="time" class="form-control border-0 bg-transparent p-0 shadow-none" id="d_inicio" value="10:00">
                                <span>a</span>
                                <input type="time" class="form-control border-0 bg-transparent p-0 shadow-none" id="d_fin" value="18:00">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Submit -->
                <div class="text-center mt-5 mb-5">
                    <button type="submit" class="btn btn-submit-premium">
                        Publicar mi negocio ahora <i class="bi bi-rocket-takeoff-fill ms-2"></i>
                    </button>
                    <p class="text-muted small mt-3">Al registrar tu negocio, aceptas nuestros <a href="#" class="text-orange text-decoration-none fw-bold">Términos y Condiciones</a>.</p>
                </div>

            </form>
        </div>
    </div>
</div>

@if (hasValidGoogleMaps)
{
    <!-- Google Maps API -->
    <script src="https://maps.googleapis.com/maps/api/js?key=@googleMapsApiKey&libraries=places&callback=initMap" async defer></script>
}
else
{
    <!-- Leaflet JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <!-- Leaflet Geocoder JS -->
    <script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>
}

<script>
    const hasValidGoogleMaps = @(hasValidGoogleMaps.ToString().ToLower());
    let map;
    let marker;
    let geocoder;
    const defaultLocation = { lat: -12.0464, lng: -77.0428 }; // Lima, Perú

    if (hasValidGoogleMaps) {
        window.initMap = function() {
            try {
                geocoder = new google.maps.Geocoder();
                
                map = new google.maps.Map(document.getElementById('map'), {
                    center: defaultLocation,
                    zoom: 13,
                    mapTypeControl: false,
                    streetViewControl: false
                });

                marker = new google.maps.Marker({
                    position: defaultLocation,
                    map: map,
                    draggable: true,
                    title: 'Ubica tu negocio aquí'
                });

                marker.addListener('dragend', function() {
                    const position = marker.getPosition();
                    updateCoordinates(position.lat(), position.lng());
                    geocodePosition(position);
                });

                map.addListener('click', function(event) {
                    marker.setPosition(event.latLng);
                    updateCoordinates(event.latLng.lat(), event.latLng.lng());
                    geocodePosition(event.latLng);
                });

                const addressInput = document.getElementById('addressInput');
                addressInput.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter') e.preventDefault();
                });

                const autocomplete = new google.maps.places.Autocomplete(addressInput);
                autocomplete.bindTo('bounds', map);

                autocomplete.addListener('place_changed', function() {
                    const place = autocomplete.getPlace();
                    if (!place.geometry || !place.geometry.location) return;
                    
                    map.setCenter(place.geometry.location);
                    map.setZoom(16);
                    marker.setPosition(place.geometry.location);
                    updateCoordinates(place.geometry.location.lat(), place.geometry.location.lng());
                });
            } catch (error) {
                console.error("Error en initMap Google:", error);
                fallbackToLeaflet();
            }
        };
    } else {
        // Inicializar Leaflet automáticamente
        document.addEventListener('DOMContentLoaded', initLeafletMap);
    }

    function initLeafletMap() {
        try {
            const defaultCoords = [defaultLocation.lat, defaultLocation.lng];
            
            map = L.map('map').setView(defaultCoords, 13);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors',
                maxZoom: 19
            }).addTo(map);

            marker = L.marker(defaultCoords, {
                draggable: true,
                title: 'Ubica tu negocio aquí'
            }).addTo(map);

            // Guardar coordenadas iniciales
            updateCoordinates(defaultLocation.lat, defaultLocation.lng);

            marker.on('dragend', function() {
                const pos = marker.getLatLng();
                updateCoordinates(pos.lat, pos.lng);
                updateAddressFromCoordinates(pos.lat, pos.lng);
            });

            map.on('click', function(event) {
                marker.setLatLng(event.latlng);
                updateCoordinates(event.latlng.lat, event.latlng.lng);
                updateAddressFromCoordinates(event.latlng.lat, event.latlng.lng);
            });

            // Buscar dirección cuando se escribe en el input
            document.getElementById('addressInput').addEventListener('change', searchAddress);
            
            // También escuchar por tecla enter en el buscador manual de Leaflet
            document.getElementById('addressInput').addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    searchAddress();
                }
            });
        } catch (error) {
            document.getElementById('map').innerHTML = '<div style="padding: 20px; color: red; font-weight: bold;">Error al cargar el mapa: ' + error.message + '</div>';
            console.error("Error en initLeafletMap:", error);
        }
    }

    function updateAddressFromCoordinates(lat, lng) {
        fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`)
            .then(response => response.json())
            .then(data => {
                if (data.display_name) {
                    document.getElementById('addressInput').value = data.display_name;
                }
            })
            .catch(error => console.log('Error al obtener la dirección:', error));
    }

    function searchAddress() {
        const address = document.getElementById('addressInput').value;
        if (!address) return;

        fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`)
            .then(response => response.json())
            .then(data => {
                if (data && data.length > 0) {
                    const result = data[0];
                    const lat = parseFloat(result.lat);
                    const lng = parseFloat(result.lon);
                    
                    if (hasValidGoogleMaps) {
                        const pos = new google.maps.LatLng(lat, lng);
                        marker.setPosition(pos);
                        map.setCenter(pos);
                        map.setZoom(15);
                    } else {
                        const coords = [lat, lng];
                        marker.setLatLng(coords);
                        map.setView(coords, 15);
                    }
                    updateCoordinates(lat, lng);
                }
            })
            .catch(error => console.error('Error buscando dirección:', error));
    }

    function updateCoordinates(lat, lng) {
        document.getElementById('latitude').value = lat;
        document.getElementById('longitude').value = lng;
    }

    function geocodePosition(pos) {
        geocoder.geocode({ location: pos }, function(results, status) {
            if (status === 'OK' && results[0]) {
                document.getElementById('addressInput').value = results[0].formatted_address;
            }
        });
    }

    document.getElementById('formRegistroNegocio').addEventListener('submit', function(e) {
        if (!document.getElementById('latitude').value || !document.getElementById('longitude').value) {
            e.preventDefault();
            alert('Por favor, selecciona una ubicación exacta en el mapa.');
        }
    });

    document.getElementById('domingo_abierto')?.addEventListener('change', function() {
        document.getElementById('domingo_horarios').style.display = 'flex';
    });

    document.getElementById('domingo_cerrado')?.addEventListener('change', function() {
        document.getElementById('domingo_horarios').style.display = 'none';
    });
</script>
