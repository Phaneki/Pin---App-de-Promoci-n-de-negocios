@{
    ViewData["Title"] = "Panel de Moderación";
    Layout = "_Layout";
}
<div class='min-h-screen bg-[#f8fafc] text-slate-900'>
    <div class='lg:flex lg:min-h-screen'>
        <aside class='fixed inset-y-0 left-0 z-20 w-72 border-r border-slate-200 bg-white p-6 shadow-sm'>
            <div class='mb-10 flex items-center gap-3'>
                <div class='flex h-11 w-11 items-center justify-center rounded-2xl bg-[#a04028] text-white shadow-sm'>
                    <span class='text-lg font-bold'>P</span>
                </div>
                <div>
                    <p class='text-sm font-semibold uppercase tracking-[0.2em] text-slate-500'>Pin Admin</p>
                    <p class='text-2xl font-semibold text-slate-900'>Moderación</p>
                </div>
            </div>
            <nav class='space-y-1 text-sm text-slate-600'>
                <a href='#' class='flex items-center gap-3 rounded-2xl px-4 py-3 transition hover:bg-slate-100'>
                    <i class='fas fa-tachometer-alt text-slate-400'></i>
                    <span>Dashboard</span>
                </a>
                <a href='#' class='flex items-center gap-3 rounded-2xl bg-[#f3e5df] px-4 py-3 text-[#a04028] shadow-sm'>
                    <i class='fas fa-store text-[#a04028]'></i>
                    <span class='font-semibold'>Negocios</span>
                </a>
                <a href='#' class='flex items-center gap-3 rounded-2xl px-4 py-3 transition hover:bg-slate-100'>
                    <i class='fas fa-tags text-slate-400'></i>
                    <span>Categorías</span>
                </a>
                <a href='#' class='flex items-center gap-3 rounded-2xl px-4 py-3 transition hover:bg-slate-100'>
                    <i class='fas fa-user-friends text-slate-400'></i>
                    <span>Usuarios</span>
                </a>
                <a href='#' class='flex items-center gap-3 rounded-2xl px-4 py-3 transition hover:bg-slate-100'>
                    <i class='fas fa-chart-line text-slate-400'></i>
                    <span>Reportes</span>
                </a>
            </nav>
            <div class='mt-12 space-y-3'>
                <button class='w-full rounded-2xl bg-[#a04028] px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[#8b3722]'>+ Nuevo Registro</button>
                <a href='#' class='flex items-center justify-between rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 transition hover:bg-slate-100'>
                    <span>Ayuda</span>
                    <i class='fas fa-question-circle text-slate-400'></i>
                </a>
                <a href='#' class='flex items-center justify-between rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 transition hover:bg-slate-100'>
                    <span>Cerrar Sesión</span>
                    <i class='fas fa-sign-out-alt text-slate-400'></i>
                </a>
            </div>
        </aside>
        <main class='ml-0 flex-1 lg:ml-72'>
            <div class='border-b border-slate-200 bg-[#f8fafc] px-6 py-5 shadow-sm'>
                <div class='flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between'>
                    <div class='flex flex-1 items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm'>
                        <i class='fas fa-search text-slate-400'></i>
                        <input type='search' placeholder='Buscar negocio, categoría o RUC' class='w-full bg-transparent text-sm text-slate-700 outline-none' />
                    </div>
                    <div class='flex flex-wrap items-center gap-3 text-sm text-slate-600'>
                        <a href='#' class='rounded-full bg-white px-4 py-3 shadow-sm transition hover:bg-slate-100'>Documentación</a>
                        <div class='flex items-center gap-3 rounded-full bg-white px-4 py-3 shadow-sm'>
                            <span class='inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#a04028]/10 text-[#a04028]'>AG</span>
                            <div>
                                <p class='font-semibold text-slate-900'>Admin Global</p>
                                <p class='text-xs text-slate-500'>Moderador principal</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <section class='space-y-6 px-6 py-6'>
                <div class='grid gap-4 md:grid-cols-3'>
                    <article class='rounded-3xl bg-white p-6 shadow-sm'>
                        <p class='text-sm font-semibold uppercase tracking-[0.2em] text-slate-500'>Solicitudes Pendientes</p>
                        <p class='mt-4 text-4xl font-semibold text-slate-900'>24</p>
                        <p class='mt-2 text-sm text-slate-500'>+4 desde ayer</p>
                    </article>
                    <article class='rounded-3xl bg-white p-6 shadow-sm'>
                        <p class='text-sm font-semibold uppercase tracking-[0.2em] text-slate-500'>Negocios Aprobados Hoy</p>
                        <p class='mt-4 text-4xl font-semibold text-slate-900'>12</p>
                        <p class='mt-2 text-sm text-slate-500'>Superando meta diaria</p>
                    </article>
                    <article class='rounded-3xl bg-white p-6 shadow-sm'>
                        <p class='text-sm font-semibold uppercase tracking-[0.2em] text-slate-500'>Tasa de Rechazo</p>
                        <p class='mt-4 text-4xl font-semibold text-slate-900'>4.2%</p>
                        <p class='mt-2 text-sm text-slate-500'>Normal operativo</p>
                    </article>
                </div>
                <div class='grid gap-6 xl:grid-cols-[8fr_4fr]'>
                    <section class='rounded-3xl bg-white p-6 shadow-sm'>
                        <div class='mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between'>
                            <div>
                                <h2 class='text-2xl font-semibold text-slate-900'>Denuncias Pendientes</h2>
                                <p class='text-sm text-slate-500'>Revisa los reportes más recientes</p>
                            </div>
                            <select class='w-full max-w-xs rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700 shadow-sm outline-none'>
                                <option>Filtrar: Todas</option>
                                <option>Más recientes</option>
                                <option>Urgentes</option>
                            </select>
                        </div>
                        <div class='overflow-x-auto'>
                            <table class='min-w-full divide-y divide-slate-200 text-left text-sm'>
                                <thead class='bg-slate-50 text-slate-700'>
                                    <tr>
                                        <th class='px-4 py-3 font-medium'>Negocio</th>
                                        <th class='px-4 py-3 font-medium'>Categoría</th>
                                        <th class='px-4 py-3 font-medium'>Fecha</th>
                                        <th class='px-4 py-3 font-medium'>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody class='divide-y divide-slate-200'>
                                    <tr>
                                        <td class='px-4 py-4'>
                                            <div class='flex items-center gap-3'>
                                                <div class='h-12 w-12 overflow-hidden rounded-2xl bg-slate-100'>
                                                    <img src='https://via.placeholder.com/48' alt='Miniatura' class='h-full w-full object-cover' />
                                                </div>
                                                <div>
                                                    <p class='font-semibold text-slate-900'>La Casa del Café</p>
                                                    <p class='text-xs text-slate-500'>Lima, Perú</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class='px-4 py-4'>
                                            <span class='inline-flex rounded-full bg-[#fde8e3] px-3 py-1 text-xs font-semibold text-[#a04028]'>Gastronomía</span>
                                        </td>
                                        <td class='px-4 py-4 text-slate-600'>19 Apr 2026</td>
                                        <td class='px-4 py-4'>
                                            <div class='flex items-center gap-2 text-slate-500'>
                                                <button class='rounded-lg p-2 transition hover:bg-slate-100'><i class='fas fa-eye'></i></button>
                                                <button class='rounded-lg p-2 text-orange-500 transition hover:bg-slate-100'><i class='fas fa-times-circle'></i></button>
                                                <button class='rounded-lg p-2 text-[#16a34a] transition hover:bg-slate-100'><i class='fas fa-check-circle'></i></button>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class='px-4 py-4'>
                                            <div class='flex items-center gap-3'>
                                                <div class='h-12 w-12 overflow-hidden rounded-2xl bg-slate-100'>
                                                    <img src='https://via.placeholder.com/48' alt='Miniatura' class='h-full w-full object-cover' />
                                                </div>
                                                <div>
                                                    <p class='font-semibold text-slate-900'>Pelusas Taurinas</p>
                                                    <p class='text-xs text-slate-500'>Arequipa, Perú</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class='px-4 py-4'>
                                            <span class='inline-flex rounded-full bg-[#e8f5ff] px-3 py-1 text-xs font-semibold text-[#2563eb]'>Servicios</span>
                                        </td>
                                        <td class='px-4 py-4 text-slate-600'>18 Apr 2026</td>
                                        <td class='px-4 py-4'>
                                            <div class='flex items-center gap-2 text-slate-500'>
                                                <button class='rounded-lg p-2 transition hover:bg-slate-100'><i class='fas fa-eye'></i></button>
                                                <button class='rounded-lg p-2 text-orange-500 transition hover:bg-slate-100'><i class='fas fa-times-circle'></i></button>
                                                <button class='rounded-lg p-2 text-[#16a34a] transition hover:bg-slate-100'><i class='fas fa-check-circle'></i></button>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class='px-4 py-4'>
                                            <div class='flex items-center gap-3'>
                                                <div class='h-12 w-12 overflow-hidden rounded-2xl bg-slate-100'>
                                                    <img src='https://via.placeholder.com/48' alt='Miniatura' class='h-full w-full object-cover' />
                                                </div>
                                                <div>
                                                    <p class='font-semibold text-slate-900'>Taller Verde</p>
                                                    <p class='text-xs text-slate-500'>Cusco, Perú</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class='px-4 py-4'>
                                            <span class='inline-flex rounded-full bg-[#f3f4f6] px-3 py-1 text-xs font-semibold text-slate-700'>Comercio</span>
                                        </td>
                                        <td class='px-4 py-4 text-slate-600'>17 Apr 2026</td>
                                        <td class='px-4 py-4'>
                                            <div class='flex items-center gap-2 text-slate-500'>
                                                <button class='rounded-lg p-2 transition hover:bg-slate-100'><i class='fas fa-eye'></i></button>
                                                <button class='rounded-lg p-2 text-orange-500 transition hover:bg-slate-100'><i class='fas fa-times-circle'></i></button>
                                                <button class='rounded-lg p-2 text-[#16a34a] transition hover:bg-slate-100'><i class='fas fa-check-circle'></i></button>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class='mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between'>
                            <p class='text-sm text-slate-500'>Mostrando 1-3 de 24 denuncias</p>
                            <div class='flex items-center gap-2'>
                                <button class='rounded-full border border-slate-200 bg-white px-3 py-2 text-sm text-slate-600 transition hover:bg-slate-50'>Anterior</button>
                                <button class='rounded-full border border-slate-200 bg-white px-3 py-2 text-sm text-slate-600 transition hover:bg-slate-50'>Siguiente</button>
                            </div>
                        </div>
                    </section>
                    <aside class='rounded-3xl bg-white p-6 shadow-sm'>
                        <h3 class='text-2xl font-semibold text-slate-900'>Guía Rápida</h3>
                        <p class='mt-2 text-sm text-slate-500'>Pasos esenciales para validar una solicitud.</p>
                        <ol class='mt-6 space-y-4 text-sm text-slate-700'>
                            <li class='rounded-3xl border border-slate-200 bg-slate-50 p-4'>
                                <span class='mb-2 inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#fde8e3] text-lg font-semibold text-[#a04028]'>1</span>
                                <p class='font-semibold'>Verificar RUC</p>
                                <p class='text-slate-500'>Confirma la identificación fiscal y la razón social.</p>
                            </li>
                            <li class='rounded-3xl border border-slate-200 bg-slate-50 p-4'>
                                <span class='mb-2 inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#e8f5ff] text-lg font-semibold text-[#2563eb]'>2</span>
                                <p class='font-semibold'>Calidad de Imagen</p>
                                <p class='text-slate-500'>Asegura fotos claras y autorizadas del local.</p>
                            </li>
                            <li class='rounded-3xl border border-slate-200 bg-slate-50 p-4'>
                                <span class='mb-2 inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#f8fafc] text-lg font-semibold text-slate-700'>3</span>
                                <p class='font-semibold'>Geolocalización</p>
                                <p class='text-slate-500'>Verifica que la dirección coincida en el mapa.</p>
                            </li>
                        </ol>
                        <button class='mt-6 w-full rounded-2xl bg-sky-500 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-600'>VER MANUAL COMPLETO</button>
                    </aside>
                </div>
                <section class='space-y-4 rounded-3xl bg-white p-6 shadow-sm'>
                    <div class='mb-4 flex items-center justify-between'>
                        <h3 class='text-xl font-semibold text-slate-900'>Actividad Reciente del Staff</h3>
                        <span class='text-sm text-slate-500'>Actualizado hace 10 min</span>
                    </div>
                    <div class='grid gap-4 sm:grid-cols-2 xl:grid-cols-4'>
                        <article class='rounded-3xl border border-slate-200 bg-slate-50 p-4 shadow-sm'>
                            <p class='text-sm text-slate-500'>Carlos M.</p>
                            <p class='mt-3 text-lg font-semibold text-slate-900'>Aprobó 3 negocios</p>
                            <p class='mt-2 text-sm text-slate-500'>Validó fotos y documentación.</p>
                        </article>
                        <article class='rounded-3xl border border-slate-200 bg-slate-50 p-4 shadow-sm'>
                            <p class='text-sm text-slate-500'>Lucía R.</p>
                            <p class='mt-3 text-lg font-semibold text-slate-900'>Revisó 5 reportes</p>
                            <p class='mt-2 text-sm text-slate-500'>Detectó inconsistencias de ubicación.</p>
                        </article>
                        <article class='rounded-3xl border border-slate-200 bg-slate-50 p-4 shadow-sm'>
                            <p class='text-sm text-slate-500'>Jorge V.</p>
                            <p class='mt-3 text-lg font-semibold text-slate-900'>Aplicó 2 rechazos</p>
                            <p class='mt-2 text-sm text-slate-500'>Motivos: documentos inválidos.</p>
                        </article>
                        <article class='rounded-3xl border border-slate-200 bg-slate-50 p-4 shadow-sm'>
                            <p class='text-sm text-slate-500'>Sistema</p>
                            <p class='mt-3 text-lg font-semibold text-slate-900'>Recordatorio</p>
                            <p class='mt-2 text-sm text-slate-500'>Revisión de panel activo hasta las 20:00.</p>
                        </article>
                    </div>
                </section>
            </section>
        </main>
    </div>
</div>
