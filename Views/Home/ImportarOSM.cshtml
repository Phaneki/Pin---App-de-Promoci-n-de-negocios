@{
    ViewData["Title"] = "Importar Negocios - OpenStreetMap";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/moderacion.css" asp-append-version="true" />
    <style>
        .premium-header {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(229, 231, 235, 0.5);
            padding: 1.25rem 2rem; position: sticky; top: 0; z-index: 40;
        }
        .search-bar { background: #f1f5f9; border: 1px solid #e2e8f0; transition: all 0.3s ease; border-radius: 100px; }
        .search-bar:focus-within { background: white; border-color: #ff6b2c; box-shadow: 0 0 0 4px rgba(255,107,44,0.15); }
    </style>
}

<div class='min-h-screen text-slate-900'>
    <div class='lg:flex lg:min-h-screen'>
        <!-- Inyectamos el Sidebar modular -->
        <partial name="_ModeracionSidebar" />
        
        <main class='flex-1 admin-main-content'>
            <!-- Header -->
            <div class='premium-header'>
                <div class='flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between w-full'>
                    <form method="get" action="/Home/NegociosAdmin" class='search-bar flex w-full max-w-md items-center gap-3 px-5 py-2.5 m-0'>
                        <i class='fas fa-search text-slate-400'></i>
                        <input type='search' name='busqueda' placeholder='Buscar negocio, usuario o reporte...' class='w-full bg-transparent text-sm font-medium text-slate-700 outline-none placeholder-slate-400' />
                    </form>
                    <div class='flex flex-wrap items-center gap-4 text-sm'>
                        <a href='/' class='font-bold text-white transition-transform hover:scale-105 flex items-center gap-2 px-4 py-2 rounded-full shadow-sm' style="background: linear-gradient(135deg, #ff6b2c, #ff8a50);">
                            <i class='fas fa-arrow-left'></i> Volver a la App
                        </a>
                        
                        <!-- Perfil Dropdown -->
                        <div class="dropdown">
                            <button class='flex items-center gap-3 rounded-full bg-white px-2 py-1.5 shadow-sm border border-slate-200 pr-4 cursor-pointer transition hover:border-[#ff6b2c]' data-bs-toggle="dropdown" aria-expanded="false" style="outline: none;">
                                @{
                                    var adminName = Context.Session.GetString("Nombre") ?? "Admin";
                                    var adminInitials = adminName.Length >= 2 ? adminName.Substring(0, 2).ToUpper() : "AD";
                                    var adminFoto = Context.Session.GetString("Foto");
                                }
                                @if (!string.IsNullOrEmpty(adminFoto))
                                {
                                    <img src="@adminFoto" alt="Perfil" class="h-9 w-9 rounded-full object-cover shadow-sm border border-slate-100" referrerpolicy="no-referrer" />
                                }
                                else
                                {
                                    <span class='inline-flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-[#ff6b2c] to-[#ff8a50] text-white font-bold shadow-sm'>@adminInitials</span>
                                }
                                <div class="text-left hidden sm:block">
                                    <p class='font-bold text-slate-900 leading-tight'>@adminName</p>
                                    <p class='text-[10px] uppercase tracking-wider font-bold text-[#ff6b2c] mt-0.5'>Moderador</p>
                                </div>
                                <i class="fas fa-chevron-down text-slate-400 ml-1 text-xs hidden sm:block"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end mt-3 border-0 shadow-xl rounded-2xl overflow-hidden min-w-[200px]" style="animation: dropdownFade 0.2s ease-out forwards;">
                                <li><a class="dropdown-item py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:text-[#ff6b2c] transition" href="/Home/Perfil"><i class="fas fa-user-circle w-5 text-center text-slate-400"></i> Mi Perfil</a></li>
                                <li><hr class="dropdown-divider my-0 border-slate-100"></li>
                                <li><a class="dropdown-item py-2.5 text-sm font-semibold text-red-600 hover:bg-red-50 transition" href="/Login/Logout"><i class="fas fa-sign-out-alt w-5 text-center"></i> Cerrar Sesión</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <section class='p-6 max-w-6xl mx-auto'>
                <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-8 gap-4">
                    <div>
                        <h1 class="text-3xl font-bold text-slate-800 tracking-tight">🌐 Importar desde OpenStreetMap</h1>
                        <p class="text-slate-500 mt-2 text-lg">Importa negocios reales de Lima usando datos abiertos de OpenStreetMap.</p>
                    </div>
                    <div class="inline-flex items-center bg-slate-100 text-slate-700 px-4 py-2 rounded-full text-sm font-bold shadow-sm border border-slate-200">
                        <span>Gratuito • Sin límites</span>
                    </div>
                </div>

                <!-- Mensajes de feedback -->
                @if (TempData["Exito"] != null)
                {
                    <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 p-4 mb-6 rounded-2xl shadow-sm flex items-center gap-3">
                        <i class="fas fa-check-circle text-2xl text-emerald-500"></i>
                        <p class="font-medium">@TempData["Exito"]</p>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="bg-red-50 border border-red-200 text-red-600 p-4 mb-6 rounded-2xl shadow-sm flex items-center gap-3">
                        <i class="fas fa-exclamation-circle text-2xl text-red-500"></i>
                        <p class="font-medium">@TempData["Error"]</p>
                    </div>
                }

                <!-- Formulario de importación -->
                <div class="bg-white rounded-3xl shadow-sm border border-slate-200 p-8 mb-8">
                    <h2 class="text-xl font-bold text-slate-800 mb-6 flex items-center gap-2">
                        <i class="fas fa-map-marker-alt text-[#ff6b2c]"></i> Configuración de importación
                    </h2>
                    
                    <form asp-action="ImportarOSM" method="post" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Latitud -->
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-2">
                                    🌍 Latitud
                                </label>
                                <input type="number" name="latitud" id="latitud"
                                       value="-12.0464"
                                       step="0.000001"
                                       min="-90"
                                       max="90"
                                       class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-[#ff6b2c] focus:border-[#ff6b2c] text-slate-800 text-base outline-none transition bg-slate-50 focus:bg-white"
                                       placeholder="-12.0464" required />
                                <p class="text-xs text-slate-500 mt-1.5 font-medium">Ej: -12.0464 (centro de Lima)</p>
                            </div>

                            <!-- Longitud -->
                            <div>
                                <label class="block text-sm font-semibold text-slate-700 mb-2">
                                    🌍 Longitud
                                </label>
                                <input type="number" name="longitud" id="longitud"
                                       value="-77.0428"
                                       step="0.000001"
                                       min="-180"
                                       max="180"
                                       class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-[#ff6b2c] focus:border-[#ff6b2c] text-slate-800 text-base outline-none transition bg-slate-50 focus:bg-white"
                                       placeholder="-77.0428" required />
                                <p class="text-xs text-slate-500 mt-1.5 font-medium">Ej: -77.0428 (centro de Lima)</p>
                            </div>
                        </div>

                        <!-- Radio -->
                        <div class="pt-2">
                            <label class="block text-sm font-semibold text-slate-700 mb-2">
                                📏 Radio de búsqueda (metros)
                            </label>
                            <input type="number" name="radio" id="radio" min="100" max="5000" step="100"
                                   value="1000"
                                   class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-[#ff6b2c] focus:border-[#ff6b2c] text-slate-800 text-base outline-none transition bg-slate-50 focus:bg-white mb-2" required />
                            <div class="flex justify-between text-xs font-bold text-slate-400 mt-2 mb-1 uppercase tracking-wider">
                                <span>100m</span>
                                <span id="radioLabel" class="text-[#ff6b2c]">1000 metros (~1 km)</span>
                                <span>5000m</span>
                            </div>
                            <!-- Slider visual (sincronizado con input numérico) -->
                            <input type="range" id="radioSlider" min="100" max="5000" step="100" value="1000"
                                   class="w-full h-2.5 bg-slate-200 rounded-full appearance-none cursor-pointer accent-[#ff6b2c]" />
                        </div>

                        <!-- Botón de importar -->
                        <div class="pt-4">
                            <button type="submit" id="btnImportar"
                                    class="w-full font-bold text-white py-4 px-6 rounded-xl transition-all duration-300 shadow-md hover:shadow-lg flex items-center justify-center gap-3 text-lg hover:-translate-y-0.5" style="background: linear-gradient(135deg, #ff6b2c, #ff8a50);">
                                <i class="fas fa-cloud-download-alt text-xl"></i>
                                Importar Negocios desde OpenStreetMap
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Información adicional -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition">
                        <div class="flex items-center justify-center w-12 h-12 bg-blue-50 text-blue-500 rounded-xl mb-4 text-xl">📍</div>
                        <h3 class="font-bold text-slate-800 mb-3">¿Qué se importa?</h3>
                        <ul class="text-sm text-slate-600 space-y-2 font-medium">
                            <li class="flex gap-2"><i class="fas fa-check text-blue-400 mt-1"></i> Restaurantes y cafeterías</li>
                            <li class="flex gap-2"><i class="fas fa-check text-blue-400 mt-1"></i> Tiendas y comercios</li>
                            <li class="flex gap-2"><i class="fas fa-check text-blue-400 mt-1"></i> Farmacias y clínicas</li>
                            <li class="flex gap-2"><i class="fas fa-check text-blue-400 mt-1"></i> Bancos y escuelas</li>
                            <li class="flex gap-2"><i class="fas fa-check text-blue-400 mt-1"></i> Hoteles y más</li>
                        </ul>
                    </div>

                    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition">
                        <div class="flex items-center justify-center w-12 h-12 bg-emerald-50 text-emerald-500 rounded-xl mb-4 text-xl">💾</div>
                        <h3 class="font-bold text-slate-800 mb-3">¿Dónde se guardan?</h3>
                        <ul class="text-sm text-slate-600 space-y-2 font-medium">
                            <li class="flex gap-2"><i class="fas fa-check text-emerald-400 mt-1"></i> En tu base de datos local</li>
                            <li class="flex gap-2"><i class="fas fa-check text-emerald-400 mt-1"></i> Con estado "Aprobado"</li>
                            <li class="flex gap-2"><i class="fas fa-check text-emerald-400 mt-1"></i> Identificados como "OSM"</li>
                            <li class="flex gap-2"><i class="fas fa-check text-emerald-400 mt-1"></i> Evitando duplicados</li>
                            <li class="flex gap-2"><i class="fas fa-check text-emerald-400 mt-1"></i> Listos para usar</li>
                        </ul>
                    </div>

                    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition">
                        <div class="flex items-center justify-center w-12 h-12 bg-purple-50 text-purple-500 rounded-xl mb-4 text-xl">🎯</div>
                        <h3 class="font-bold text-slate-800 mb-3">Coordenadas útiles</h3>
                        <ul class="text-sm text-slate-600 space-y-2 font-medium">
                            <li class="flex gap-2"><i class="fas fa-map-marker-alt text-purple-400 mt-1"></i> <strong>Centro:</strong> -12.046, -77.042</li>
                            <li class="flex gap-2"><i class="fas fa-map-marker-alt text-purple-400 mt-1"></i> <strong>Miraflores:</strong> -12.121, -77.030</li>
                            <li class="flex gap-2"><i class="fas fa-map-marker-alt text-purple-400 mt-1"></i> <strong>S. Isidro:</strong> -12.098, -77.036</li>
                            <li class="flex gap-2"><i class="fas fa-map-marker-alt text-purple-400 mt-1"></i> <strong>Surco:</strong> -12.148, -76.996</li>
                            <li class="flex gap-2"><i class="fas fa-map-marker-alt text-purple-400 mt-1"></i> <strong>Molina:</strong> -12.078, -76.944</li>
                        </ul>
                    </div>
                </div>

                <!-- Nota importante -->
                <div class="bg-amber-50 border border-amber-200 p-5 mt-8 rounded-2xl flex items-start gap-4">
                    <div class="flex items-center justify-center w-10 h-10 bg-amber-100 text-amber-600 rounded-full shrink-0">
                        <i class="fas fa-lightbulb text-lg"></i>
                    </div>
                    <div>
                        <p class="font-bold text-amber-900">Consejo para empezar</p>
                        <p class="text-sm font-medium text-amber-700 mt-1">
                            Usa las coordenadas del centro de Lima (-12.0464, -77.0428) con un radio de 1000m 
                            para obtener tus primeros negocios. Luego puedes importar de otras zonas.
                        </p>
                    </div>
                </div>
            </section>
        </main>
    </div>
</div>

@section Scripts {
    <script>
        // Sincronizar slider con input numérico (y vice versa)
        const radioInput = document.getElementById('radio');
        const radioSlider = document.getElementById('radioSlider');
        const radioLabel = document.getElementById('radioLabel');

        // Cuando cambias el slider
        radioSlider.addEventListener('input', function() {
            radioInput.value = this.value;
            updateLabel();
        });

        // Cuando cambias el input numérico
        radioInput.addEventListener('input', function() {
            radioSlider.value = this.value;
            updateLabel();
        });

        function updateLabel() {
            const valor = radioInput.value;
            const km = Math.round(valor / 1000 * 10) / 10;
            radioLabel.textContent = valor + ' metros (~' + km + ' km)';
        }

        // Manejar el submit del formulario
        document.querySelector('form').addEventListener('submit', function(e) {
            const btnImportar = document.getElementById('btnImportar');
            btnImportar.disabled = true;
            btnImportar.innerHTML = '<svg class="animate-spin h-5 w-5 mr-3 inline" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg> Importando...';
        });
    </script>
}