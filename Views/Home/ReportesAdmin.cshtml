@{
    ViewData["Title"] = "Gestión de Reportes";
    Layout = "_Layout";
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
}
@model IEnumerable<PinAppdePromo.Models.BusinessReport>
@section Styles {
    <link rel="stylesheet" href="~/css/moderacion.css" asp-append-version="true" />
}

<div class='min-h-screen text-slate-900'>
    <div class='lg:flex lg:min-h-screen'>
        <!-- Inyectamos el Sidebar modular -->
        <partial name="_ModeracionSidebar" />
        
        <main class='flex-1 admin-main-content'>
            <div class='admin-header px-6 py-5 shadow-sm'>
                <div class='flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between'>
                    <h1 class="text-2xl font-bold text-slate-800">Gestión de Reportes</h1>
                    <div class='flex flex-wrap items-center gap-3 text-sm text-slate-600'>
                        <div class='flex items-center gap-3 rounded-full bg-white px-4 py-3 shadow-sm'>
                            @{
                                var adminName = Context.Session.GetString("Nombre") ?? "Admin";
                                var adminInitials = adminName.Length >= 2 ? adminName.Substring(0, 2).ToUpper() : "AD";
                            }
                            <span class='inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#ff6b00]/10 text-[#ff6b00]'>@adminInitials</span>
                            <div>
                                <p class='font-semibold text-slate-900'>@adminName</p>
                                <p class='text-xs text-slate-500'>Moderador principal</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <section class='p-6 max-w-6xl mx-auto'>
                <div class="mb-6">
                    <h2 class="text-lg font-bold text-slate-800">Bandeja de Denuncias</h2>
                    <p class="text-sm text-slate-500 mt-1">Revisa las denuncias de la comunidad. Puedes sancionar los negocios infractores o descartar reportes falsos.</p>
                </div>

                <!-- BARRA DE BÚSQUEDA Y FILTROS -->
                <form method="get" asp-action="ReportesAdmin" class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between bg-white p-4 rounded-2xl shadow-sm border border-slate-200">
                    <div class="flex flex-1 items-center gap-3 w-full sm:max-w-md border border-slate-300 rounded-xl px-4 py-2 focus-within:border-[#ff6b00] focus-within:ring-1 focus-within:ring-[#ff6b00] transition bg-slate-50">
                        <i class="fas fa-search text-slate-400"></i>
                        <input type="text" name="busqueda" value="@ViewBag.Busqueda" placeholder="Buscar negocio denunciado..." class="w-full bg-transparent outline-none text-sm" />
                    </div>
                    <div class="flex items-center gap-3 w-full sm:w-auto">
                        <select name="filtroEstado" class="w-full sm:w-auto border border-slate-300 rounded-xl px-4 py-2 text-sm outline-none focus:border-[#ff6b00] bg-slate-50" onchange="this.form.submit()">
                            <option value="TODOS">Todos los estados</option>
                            <option value="Open" selected="@(ViewBag.FiltroEstado == "Open")">Abiertos (Pendientes)</option>
                            <option value="Resolved" selected="@(ViewBag.FiltroEstado == "Resolved")">Resueltos (Sancionados)</option>
                            <option value="Closed" selected="@(ViewBag.FiltroEstado == "Closed")">Cerrados (Descartados)</option>
                        </select>
                        <button type="submit" class="inline-flex items-center justify-center gap-2 bg-[#ff6b00] text-white px-5 py-2 rounded-xl text-sm font-semibold hover:bg-[#e66000] transition shadow-sm">
                            <i class="fas fa-filter"></i> Filtrar
                        </button>
                    </div>
                </form>

                <div class='admin-card overflow-hidden rounded-2xl shadow-sm'>
                    <div class="overflow-x-auto">
                        <table class='admin-table min-w-full divide-y divide-slate-200 text-left text-sm'>
                            <thead class='bg-slate-50 text-slate-500'>
                                <tr>
                                    <th scope="col" class='px-6 py-4 font-medium uppercase tracking-wider text-xs'>Negocio Reportado</th>
                                    <th scope="col" class='px-6 py-4 font-medium uppercase tracking-wider text-xs'>Fecha</th>
                                    <th scope="col" class='px-6 py-4 font-medium uppercase tracking-wider text-xs'>Estado</th>
                                    <th scope="col" class='px-6 py-4 font-medium uppercase tracking-wider text-xs text-right'>Resolución</th>
                                </tr>
                            </thead>
                            <tbody class='divide-y divide-slate-100 bg-white'>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var reporte in Model)
                                    {
                                        <tr>
                                            <td class='px-6 py-4'>
                                                <div class='flex items-center gap-3'>
                                                    <div class='h-12 w-12 flex-shrink-0 overflow-hidden rounded-lg bg-slate-100 border border-slate-200'>
                                                        <img src='@(reporte.Business?.Images?.FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/48")' alt='Miniatura' class='h-full w-full object-cover' />
                                                    </div>
                                                    <div>
                                                        <p class='font-semibold text-slate-900'>@(reporte.Business?.TradeName ?? "Negocio Desconocido")</p>
                                                        <p class='text-xs text-slate-500 mt-0.5'>Motivo: Contenido inapropiado / Inválido</p>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class='px-6 py-4 text-slate-600 font-medium'>
                                                @reporte.CreatedAt.ToString("dd MMM yyyy, HH:mm")
                                            </td>
                                            <td class='px-6 py-4'>
                                                @if (reporte.ReportStatus == "Open")
                                                {
                                                    <span class='inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700 border border-amber-200'>
                                                        <span class="h-1.5 w-1.5 rounded-full bg-amber-500"></span> Pendiente
                                                    </span>
                                                }
                                                else if (reporte.ReportStatus == "Resolved")
                                                {
                                                    <span class='inline-flex items-center gap-1.5 rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-700 border border-red-200'>
                                                        <i class="fas fa-gavel text-[10px]"></i> Sancionado
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class='inline-flex items-center gap-1.5 rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 border border-slate-300'>
                                                        <i class="fas fa-check text-[10px]"></i> Descartado
                                                    </span>
                                                }
                                            </td>
                                            <td class='px-6 py-4 text-right'>
                                                @if (reporte.ReportStatus == "Open")
                                                {
                                                    <div class="flex items-center justify-end gap-2 flex-wrap">
                                                        <form asp-action="ResolverReporte" asp-controller="Home" method="post" class="m-0 inline" onsubmit="return confirm('¿Descartar esta denuncia? El negocio no será penalizado.');">
                                                            <input type="hidden" name="reportId" value="@reporte.ReportId" />
                                                            <input type="hidden" name="accion" value="DESCARTAR" />
                                                            <input type="hidden" name="returnUrl" value="@currentUrl" />
                                                            <button type="submit" class='inline-flex items-center gap-1.5 rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-1.5 text-xs font-medium text-emerald-700 shadow-sm transition hover:bg-emerald-600 hover:text-white'>
                                                                <i class='fas fa-check-circle'></i> Descartar
                                                            </button>
                                                        </form>
                                                        <form asp-action="ResolverReporte" asp-controller="Home" method="post" class="m-0 inline" onsubmit="return confirm('¿Sancionar este negocio? El negocio pasará a estado RECHAZADO y dejará de estar visible en la plataforma.');">
                                                            <input type="hidden" name="reportId" value="@reporte.ReportId" />
                                                            <input type="hidden" name="accion" value="SANCIONAR" />
                                                            <input type="hidden" name="returnUrl" value="@currentUrl" />
                                                            <button type="submit" class='inline-flex items-center gap-1.5 rounded-lg border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-medium text-red-600 shadow-sm transition hover:bg-red-600 hover:text-white'>
                                                                <i class='fas fa-gavel'></i> Sancionar
                                                            </button>
                                                        </form>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-xs text-slate-400 font-medium">Reporte cerrado</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="px-6 py-12 text-center">
                                            <div class="flex flex-col items-center justify-center">
                                                <i class="fas fa-shield-check text-4xl text-slate-300 mb-3"></i>
                                                <p class="text-base font-semibold text-slate-900">Bandeja limpia</p>
                                                <p class="text-sm text-slate-500 mt-1">No hay denuncias con los filtros seleccionados.</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <!-- PAGINACIÓN -->
                    @if (ViewBag.TotalReportes > 0)
                    {
                        <div class='border-t border-slate-200 bg-slate-50/50 p-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between'>
                            <p class='text-sm text-slate-500 font-medium'>Mostrando @Model.Count() de @ViewBag.TotalReportes reportes</p>
                            <div class='flex items-center gap-2'>
                                @if (ViewBag.PaginaActual > 1) {
                                    <a href="?busqueda=@ViewBag.Busqueda&filtroEstado=@ViewBag.FiltroEstado&pagina=@(ViewBag.PaginaActual - 1)" class='rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-600 shadow-sm transition hover:bg-slate-50'>Anterior</a>
                                }
                                @for (int i = 1; i <= ViewBag.TotalPaginas; i++) {
                                    <a href="?busqueda=@ViewBag.Busqueda&filtroEstado=@ViewBag.FiltroEstado&pagina=@i" class='rounded-lg border @(i == ViewBag.PaginaActual ? "border-[#ff6b00] bg-[#ff6b00] text-white" : "border-slate-300 bg-white text-slate-600 hover:bg-slate-50") px-3 py-1.5 text-sm font-medium shadow-sm transition'>@i</a>
                                }
                                @if (ViewBag.PaginaActual < ViewBag.TotalPaginas) {
                                    <a href="?busqueda=@ViewBag.Busqueda&filtroEstado=@ViewBag.FiltroEstado&pagina=@(ViewBag.PaginaActual + 1)" class='rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-600 shadow-sm transition hover:bg-slate-50'>Siguiente</a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </section>
        </main>
    </div>
</div>