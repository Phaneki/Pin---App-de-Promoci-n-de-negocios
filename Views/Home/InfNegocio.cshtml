@model Pin___App_de_Promoci_n_de_negocios.Models.Negocio

@{
    ViewData["Title"] = Model.Nombre;
}

@section Styles {
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <h1 class="h3 mb-0 me-3">@Model.Nombre</h1>
                        @if (Model.Destacado)
                        {
                            <span class="badge bg-warning text-dark">DESTACADO</span>
                        }
                    </div>
                    <p class="text-muted mb-2"><i class="bi bi-tag me-1"></i>@Model.Categoria</p>
                    <p class="text-muted mb-2"><i class="bi bi-geo-alt me-1"></i>@Model.Direccion</p>
                    <div class="d-flex align-items-center mb-3">
                        <span class="badge bg-light text-dark me-2"><i class="bi bi-star-fill text-warning me-1"></i>@Model.Calificacion</span>
                        <span class="text-@(Model.EstaAbierto ? "success" : "danger")">
                            <i class="bi bi-clock me-1"></i>@(Model.EstaAbierto ? "Abierto" : "Cerrado")
                        </span>
                    </div>
                    <p class="card-text">@Model.Descripcion</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm mt-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Información de Contacto</h5>
                </div>
                <div class="card-body">
                    <p><strong>Horarios:</strong> @Model.Horarios</p>
                    <p><strong>Teléfono:</strong> @Model.Contacto</p>
                    <p><strong>Sitio Web:</strong> <a href="http://@Model.SitioWeb" target="_blank">@Model.SitioWeb</a></p>
                </div>
            </div>

            <!-- Información ficticia adicional correlacionada -->
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Comentarios y Reseñas</h5>
                </div>
                <div class="card-body">
                    @if (Model.Id == 1)
                    {
                        <div class="mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <span class="fw-bold me-2">María García</span>
                                <span class="text-warning">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </span>
                            </div>
                            <p class="mb-0">"El ceviche aquí es increíble, definitivamente el mejor de Miraflores. Los anticuchos también son deliciosos."</p>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <span class="fw-bold me-2">Carlos López</span>
                                <span class="text-warning">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </span>
                            </div>
                            <p class="mb-0">"Buen servicio y ambiente familiar. Recomiendo el lomo saltado."</p>
                        </div>
                    }
                    else if (Model.Id == 2)
                    {
                        <div class="mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <span class="fw-bold me-2">Ana Torres</span>
                                <span class="text-warning">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </span>
                            </div>
                            <p class="mb-0">"Precios razonables y buena variedad de productos. Ideal para compras rápidas."</p>
                        </div>
                    }
                    else if (Model.Id == 3)
                    {
                        <div class="mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <span class="fw-bold me-2">Pedro Ramírez</span>
                                <span class="text-warning">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </span>
                            </div>
                            <p class="mb-0">"Excelente supermercado con productos frescos. La entrega es rápida y eficiente."</p>
                        </div>
                    }
                    else if (Model.Id == 4)
                    {
                        <div class="mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <span class="fw-bold me-2">Lucía Mendoza</span>
                                <span class="text-warning">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </span>
                            </div>
                            <p class="mb-0">"El mejor café de la zona. Los pasteles son artesanales y deliciosos. Ambiente perfecto para trabajar."</p>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex align-items-center mb-2">
                                <span class="fw-bold me-2">Roberto Silva</span>
                                <span class="text-warning">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </span>
                            </div>
                            <p class="mb-0">"Café orgánico de alta calidad. El servicio es amable y el lugar es muy acogedor."</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
                    {
                        <img src="@Url.Content(Model.ImagenUrl)" class="img-fluid rounded mb-3" alt="@Model.Nombre" />
                    }
                    else
                    {
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded mb-3" style="height: 200px;">
                            <h4 class="fw-bold">@Model.Nombre</h4>
                        </div>
                    }
                    <a href="#" class="btn btn-primary w-100 mb-2">Visitar Sitio Web</a>
                    <a href="tel:@Model.Contacto" class="btn btn-outline-primary w-100">Llamar</a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a href="@Url.Action("Explorar", "Home")" class="btn btn-secondary">← Volver a Explorar</a>
    </div>
</div>
