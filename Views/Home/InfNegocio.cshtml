@model PinAppdePromo.Models.Business
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = Model.TradeName;
    var rawCover = Model.Images?.FirstOrDefault()?.ImageUrl?.Trim();
    var coverImage = "linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%)";
    if (!string.IsNullOrEmpty(rawCover)) {
        if (rawCover.StartsWith("~/")) {
            coverImage = Url.Content(rawCover);
        } else if (!rawCover.StartsWith("http", StringComparison.OrdinalIgnoreCase) && !rawCover.StartsWith("/") && !rawCover.StartsWith("data:image")) {
            coverImage = "/images/businesses/" + rawCover;
        } else {
            coverImage = rawCover;
        }
    }

    // Uso de dynamic para prevenir errores si aún no agregas 'Services' o 'Products' a tu modelo Business
    dynamic dynModel = Model;
    IEnumerable<dynamic> services = null;
    IEnumerable<dynamic> products = null;
    try { services = dynModel.Services; } catch { }
    try { products = dynModel.Products; } catch { }

    var lat = Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
    var lng = Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
    var googleMapsApiKey = Configuration["GoogleMaps:ApiKey"] ?? "";
}

<!-- Hero Section -->
<section class="hero-section position-relative" style="background: url('@Url.Content(coverImage)'); background-size: cover; background-position: center;">
    <div class="hero-overlay"></div>
    <div class="container text-white position-relative pb-4">
        <div class="hero-content-glass d-inline-block p-4 p-md-5">
            <h1 class="display-4 fw-bolder mb-2 text-white">@Model.TradeName</h1>
            <p class="lead text-white-50 mb-4 fw-medium"><i class="bi bi-geo-alt-fill text-terracota me-2"></i>@Model.Address</p>
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-white text-dark py-2 px-3 rounded-pill shadow-sm fs-6">
                    <i class="bi bi-star-fill text-warning me-1"></i> @(Model.Reviews?.Any() == true ? Math.Round(Model.Reviews.Average(r => r.Rating), 1) : 5.0)
                </span>
                <span class="badge" style="background: rgba(34, 197, 94, 0.2); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.3); padding: 0.5rem 1rem; border-radius: 9999px;">
                    <i class="bi bi-circle-fill me-1" style="font-size: 0.6rem; vertical-align: middle;"></i> Abierto ahora
                </span>
            </div>
        </div>
    </div>
</section>

<div class="container my-5">
    <div class="row">
        <!-- Sidebar de Contacto (Izquierda) -->
        <aside class="col-lg-4 mb-4">
            <div class="card contact-sidebar shadow-sm">
                <div class="card-body p-3 p-md-4">
                    <h5 class="fw-bold mb-3">Información de Contacto</h5>
                    
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <a href="https://www.google.com/maps/search/?api=1&query=@lat,@lng" target="_blank" class="btn btn-terracota w-100 py-2 fs-6" style="padding-left:0; padding-right:0;">
                                <i class="bi bi-geo-alt"></i> Cómo llegar
                            </a>
                        </div>
                        <div class="col-6">
                            <a href="tel:@(string.IsNullOrEmpty(Model.ContactPhone) ? "" : Model.ContactPhone)" class="btn btn-outline-secondary rounded-pill fw-semibold w-100 py-2 fs-6 @(string.IsNullOrEmpty(Model.ContactPhone) ? "disabled" : "")" style="padding-left:0; padding-right:0;">
                                <i class="bi bi-telephone"></i> Llamar
                            </a>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-start mb-2">
                        <div class="text-terracota me-2 mt-1"><i class="bi bi-geo-alt fs-5"></i></div>
                        <div>
                            <span class="d-block fw-semibold text-dark fs-6">Dirección</span>
                            <span class="text-muted" style="font-size: 0.85rem;">@Model.Address</span>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-start mb-3">
                        <div class="text-terracota me-2 mt-1"><i class="bi bi-telephone fs-5"></i></div>
                        <div>
                            <span class="d-block fw-semibold text-dark fs-6">Teléfono</span>
                            <span class="text-muted" style="font-size: 0.85rem;">@(string.IsNullOrEmpty(Model.ContactPhone) ? "Sin teléfono" : Model.ContactPhone)</span>
                        </div>
                    </div>
                    
                    <!-- Horarios dinámicos cargados con JavaScript -->
                    <div id="businessHoursContainer" class="mb-3"></div>
                    
                    <div class="rounded-4 overflow-hidden shadow-sm" style="height: 140px;">
                        <div id="businessMap" class="w-100 h-100 bg-light" style="z-index: 1;"></div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Contenido Principal (Derecha) -->
        <main class="col-lg-8">
            <!-- Sobre nosotros -->
            <section class="mb-5 pt-3">
                <h2 class="section-title">Sobre nosotros</h2>
                <p class="text-muted fs-5 lh-lg mb-5" style="max-width: 90%;">@Model.Description</p>
                
                <h3 class="fw-bold mb-4">Nuestros Servicios</h3>
                <div class="row g-4">
                    @if (services != null)
                    {
                        foreach (var service in services)
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="service-box">
                                    <div class="service-icon">
                                        <i class="bi bi-check2-circle"></i>
                                    </div>
                                    <h6 class="fw-bold text-dark mb-2">@service.Name</h6>
                                    <p class="text-muted small mb-0">@service.Description</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <p class="text-muted fst-italic px-3 py-4 bg-light rounded-4 border">Los servicios se cargarán dinámicamente desde la base de datos.</p>
                        </div>
                    }
                </div>
            </section>

            <!-- Horarios de Atención -->
            <section class="mb-5">
                <div id="scheduleContainer">
                    <div class="text-center">
                        <div class="spinner-border spinner-border-sm text-muted" role="status">
                            <span class="visually-hidden">Cargando...</span>
                        </div>
                        <p class="text-muted mt-2">Cargando horarios...</p>
                    </div>
                </div>
            </section>

            <!-- Galería de Fotos -->
            @if (Model.Images?.Any() == true)
            {
                <section class="mb-5 pt-2">
                    <h2 class="section-title">
                        Galería
                    </h2>
                    <div id="businessGalleryCarousel" class="carousel slide shadow-lg" data-bs-ride="carousel">
                        <div class="carousel-inner rounded-3">
                            @for (int i = 0; i < Model.Images.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    @{
                                        var rawGalUrl = Model.Images.ElementAt(i).ImageUrl?.Trim();
                                        var galUrl = rawGalUrl;
                                        if (!string.IsNullOrEmpty(rawGalUrl)) {
                                            if (rawGalUrl.StartsWith("~/")) {
                                                galUrl = Url.Content(rawGalUrl);
                                            } else if (!rawGalUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) && !rawGalUrl.StartsWith("/") && !rawGalUrl.StartsWith("data:image")) {
                                                galUrl = "/images/businesses/" + rawGalUrl;
                                            }
                                        }
                                    }
                                    <img src="@galUrl" class="d-block w-100" alt="@Model.TradeName" style="height: 400px; object-fit: cover;" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                    <div class="align-items-center justify-content-center w-100 fallback-img" style="height: 400px; background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); display: none !important;">
                                        <div class="text-center">
                                            <i class="bi bi-image" style="font-size: 4rem; color: #adb5bd; margin-bottom: 8px; display: block;"></i>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        @if (Model.Images.Count > 1)
                        {
                            <button class="carousel-control-prev" type="button" data-bs-target="#businessGalleryCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Anterior</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#businessGalleryCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Siguiente</span>
                            </button>

                            <!-- Indicadores -->
                            <div class="carousel-indicators">
                                @for (int i = 0; i < Model.Images.Count; i++)
                                {
                                    <button type="button" data-bs-target="#businessGalleryCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-label="Foto @(i + 1)"></button>
                                }
                            </div>
                        }
                    </div>
                </section>
            }
            <section class="mb-5 pt-2">
                <h2 class="section-title">Productos Destacados</h2>
                <div class="row g-4 mt-2">
                    @if (products != null)
                    {
                        foreach (var product in products)
                        {
                            <div class="col-md-6 col-lg-4">
                                <div class="card product-card border-0 h-100 overflow-hidden">
                                    <div class="card-body p-4 d-flex flex-column">
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <h5 class="card-title fw-bold mb-0">@product.Name</h5>
                                        </div>
                                        <p class="card-text text-muted small flex-grow-1">@product.Description</p>
                                        <div class="mt-3 pt-3 border-top">
                                            <span class="price fw-bolder">S/ @product.Price</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <p class="text-muted fst-italic px-3 py-4 bg-light rounded-4 border">Los productos destacados se cargarán dinámicamente desde la base de datos.</p>
                        </div>
                    }
                </div>
            </section>

            <!-- Crear Reseña -->
            <section class="mb-5">
                <div class="card review-action-card border-0 overflow-hidden position-relative p-0">
                    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(135deg, rgba(255,107,0,0.05), rgba(255,140,51,0.1)); z-index: 0;"></div>
                    <div class="card-body p-5 position-relative z-1 d-flex flex-column flex-md-row justify-content-between align-items-center gap-4 text-center text-md-start">
                        <div>
                            <h3 class="fw-bold mb-2">Cuéntanos tu experiencia</h3>
                            <p class="mb-0 text-muted">Tu opinión ayuda a otros clientes a descubrir los mejores lugares.</p>
                        </div>
                        <button id="openReviewForm" class="btn btn-terracota px-4 py-3 fw-bold shadow-lg">
                            <i class="fa-solid fa-star me-2"></i> Crear reseña
                        </button>
                    </div>
                </div>
            </section>

            <!-- Testimonios -->
            <section class="pb-5">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
                    <div>
                        <h2 class="section-title mb-1">Experiencias de Clientes</h2>
                        <p class="text-muted mb-0">Lo que dicen las personas sobre @Model.TradeName</p>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <label class="mb-0 text-muted">Ordenar por:</label>
                        <select id="sortReviews" class="form-select form-select-sm" style="width: auto; min-width: 180px;">
                            <option value="recent">Más recientes</option>
                            <option value="best">Mejor calificación</option>
                            <option value="worst">Peor calificación</option>
                        </select>
                    </div>
                </div>

                <div id="reviewList" class="row g-4"></div>

                <div class="mt-4 text-center">
                    <button id="openAllReviews" class="btn btn-link text-terracota fw-semibold">Ver más reseñas</button>
                </div>
            </section>
        </main>
    </div>
</div>

<style>
    /* Estilos mejorados para el Modal de Reseñas */
    #newReviewModal .modal-card {
        border-radius: 1.5rem;
        border: none;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        background: #fff;
    }
    #newReviewModal .modal-header {
        background: linear-gradient(135deg, #fffcf7 0%, #fff5eb 100%);
        border-bottom: 1px solid rgba(255,107,0,0.1);
        padding: 1.5rem 2rem;
    }
    #newReviewModal .modal-body {
        padding: 2rem;
    }
    .star-rating-container .star-btn {
        background: transparent;
        border: none;
        font-size: 3rem;
        color: #e5e7eb;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 0;
        margin: 0 0.25rem;
    }
    .star-rating-container .star-btn:hover {
        transform: scale(1.15);
    }
    .star-rating-container .star-btn.active {
        color: #ff6b00;
        filter: drop-shadow(0 4px 6px rgba(255,107,0,0.3));
    }
    .review-textarea {
        border-radius: 1rem;
        border: 2px solid #f3f4f6;
        padding: 1rem;
        resize: none;
        transition: all 0.3s ease;
        background-color: #f9fafb;
    }
    .review-textarea:focus {
        border-color: #ff6b00;
        box-shadow: 0 0 0 4px rgba(255,107,0,0.1);
        background-color: #fff;
        outline: none;
    }
    .upload-dropzone-modern {
        border: 2px dashed #e5e7eb;
        border-radius: 1rem;
        background-color: #f9fafb;
        padding: 2rem;
        text-align: center;
        transition: all 0.3s ease;
        cursor: pointer;
    }
    .upload-dropzone-modern:hover, .upload-dropzone-modern.active {
        border-color: #ff6b00;
        background-color: #fff5eb;
    }
    .upload-dropzone-modern i {
        font-size: 2.5rem;
        color: #ff6b00;
        margin-bottom: 1rem;
        transition: transform 0.3s ease;
    }
    .upload-dropzone-modern:hover i {
        transform: translateY(-5px);
    }
    .btn-publish {
        background: linear-gradient(135deg, #ff6b00, #ff8c33);
        border: none;
        border-radius: 0.75rem;
        padding: 0.75rem 2rem;
        font-weight: 700;
        color: white;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(255,107,0,0.2);
    }
    .btn-publish:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(255,107,0,0.3);
        color: white;
    }
    .btn-cancel-modern {
        border-radius: 0.75rem;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
        color: #6b7280;
        background: white;
        border: 1px solid #e5e7eb;
        transition: all 0.2s ease;
    }
    .btn-cancel-modern:hover {
        background: #f3f4f6;
        color: #374151;
    }
</style>

<div id="newReviewModal" class="modal-overlay" aria-hidden="true">
    <div class="modal-card" style="max-width: 650px; width: 95%;">
        <div class="modal-header d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-1 fw-bold text-dark">Cuéntanos tu experiencia</h4>
                <p class="text-muted mb-0" style="font-size: 0.95rem;">Tu opinión es muy valiosa para nosotros y la comunidad.</p>
            </div>
            <button id="closeReviewModal" class="btn btn-light rounded-circle shadow-sm d-flex align-items-center justify-content-center p-0" style="width: 36px; height: 36px;" aria-label="Cerrar modal">
                <i class="fa-solid fa-xmark text-muted"></i>
            </button>
        </div>
        <div class="modal-body">
            <form id="newReviewForm" asp-action="AgregarResena" asp-controller="Home" method="post" enctype="multipart/form-data" class="row g-4">
                <input type="hidden" name="BusinessId" value="@Model.BusinessId" />
                
                <div class="col-12 text-center mt-2">
                    <label class="form-label fw-bold text-muted mb-3 text-uppercase" style="font-size: 0.8rem; letter-spacing: 1px;">¿Cómo calificarías este negocio?</label>
                    <div class="star-rating-container d-flex justify-content-center" id="reviewStars">
                        @for (var i = 1; i <= 5; i++)
                        {
                            <button type="button" class="star-btn" data-value="@i" aria-label="@i estrellas">
                                <i class="fa-solid fa-star"></i>
                            </button>
                        }
                    </div>
                    <input type="hidden" id="reviewRating" name="Rating" value="5" />
                </div>

                <div class="col-12">
                    <label class="form-label fw-bold text-dark mb-2">Detalles de tu reseña</label>
                    <textarea id="reviewComment" name="Comment" class="form-control review-textarea" rows="4" placeholder="Ej. El servicio fue excelente, los precios justos y el ambiente muy agradable. ¡Lo recomiendo!" required></textarea>
                </div>

                <div class="col-12">
                    <label class="form-label fw-bold text-dark mb-2">Añadir fotos <span class="text-muted fw-normal">(Opcional)</span></label>
                    <div id="dropZone" class="upload-dropzone-modern">
                        <input type="file" id="reviewPhoto" name="Images" accept="image/*" multiple class="d-none" />
                        <div class="d-flex flex-column align-items-center">
                            <i class="fa-solid fa-camera-retro"></i>
                            <h6 class="mb-1 fw-bold text-dark">Haz clic para subir fotos o arrástralas aquí</h6>
                            <p class="small text-muted mb-0">Puedes subir hasta 5 imágenes (JPG, PNG)</p>
                        </div>
                    </div>
                    <div id="reviewPhotoPreview" class="review-photo-gallery mt-3 d-flex gap-2 flex-wrap"></div>
                </div>

                <div class="col-12 d-flex justify-content-end gap-3 mt-2 pt-4 border-top">
                    <button type="button" id="cancelReview" class="btn-cancel-modern">Cancelar</button>
                    <button type="submit" class="btn-publish">Publicar reseña <i class="fa-solid fa-paper-plane ms-1"></i></button>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="allReviewsModal" class="modal-overlay" aria-hidden="true">
    <div class="modal-card">
        <div class="modal-header">
            <div>
                <h4 class="mb-1">Todas las reseñas</h4>
                <p class="text-muted mb-0">Revisa todas las experiencias y ordena según prefieras.</p>
            </div>
            <button id="closeAllReviewsModal" class="modal-close" aria-label="Cerrar modal"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
                <div>
                    <p class="mb-0 text-muted">Ordenar reseñas dentro del popup</p>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <label class="mb-0 text-muted">Ordenar por:</label>
                    <select id="sortReviewsModal" class="form-select form-select-sm" style="width: auto; min-width: 160px;">
                        <option value="recent">Más recientes</option>
                        <option value="best">Mejor calificación</option>
                        <option value="worst">Peor calificación</option>
                    </select>
                </div>
            </div>
            <div id="allReviewList" class="row g-4"></div>
        </div>
    </div>
</div>
    </div>
</div>

@section Scripts {
    <!-- Google Maps JS -->
    <script src="https://maps.googleapis.com/maps/api/js?key=@googleMapsApiKey&callback=initBusinessMap" async defer></script>

    <script>
        // Serializamos dinámicamente las reseñas que vienen de tu Base de Datos
        @{
            var reviewsList = new List<object>();
            if (Model.Reviews != null)
            {
                foreach (var r in Model.Reviews)
                {
                    reviewsList.Add(new {
                        id = r.ReviewId,
                        nombre = r.User?.FullName ?? "Cliente Anónimo",
                        calificacion = r.Rating,
                        comentario = r.Comment ?? "Sin comentarios",
                        fecha = r.CreatedAt,
                        verificado = true
                    });
                }
            }
            var jsonReviews = System.Text.Json.JsonSerializer.Serialize(reviewsList);
        }

        const negocioId = @Model.BusinessId;
        
        // Reemplazamos los datos de prueba por la información real
        const defaultReviews = @Html.Raw(jsonReviews);

        const newReviewModal = document.getElementById('newReviewModal');
        const allReviewsModal = document.getElementById('allReviewsModal');
        const openReviewForm = document.getElementById('openReviewForm');
        const openAllReviews = document.getElementById('openAllReviews');
        const closeReviewModal = document.getElementById('closeReviewModal');
        const closeAllReviewsModal = document.getElementById('closeAllReviewsModal');
        const cancelReview = document.getElementById('cancelReview');
        const newReviewForm = document.getElementById('newReviewForm');
        const reviewList = document.getElementById('reviewList');
        const allReviewList = document.getElementById('allReviewList');
        const sortReviews = document.getElementById('sortReviews');
        const sortReviewsModal = document.getElementById('sortReviewsModal');
        const starButtons = document.querySelectorAll('#reviewStars .star-btn');
        const reviewRating = document.getElementById('reviewRating');
        const reviewPhoto = document.getElementById('reviewPhoto');
        const reviewPhotoPreview = document.getElementById('reviewPhotoPreview');

        let allReviews = [];
        let selectedFiles = [];

        function loadReviews() {
            // Ya no leemos del localStorage, cargamos la información de la DB
            allReviews = defaultReviews;
            sortAndRender();
        }

        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleDateString('es-PE', { day: 'numeric', month: 'short', year: 'numeric' });
        }

        function renderStars(count) {
            let stars = '';
            for (let i = 1; i <= 5; i++) {
                stars += `<i class="fa-solid fa-star ${i <= count ? 'text-warning' : 'text-muted'}"></i> `;
            }
            return stars;
        }

        function renderReviews() {
            reviewList.innerHTML = '';
            const reviewsToShow = allReviews.slice(0, 2);
            reviewsToShow.forEach(review => {
                const card = document.createElement('div');
                card.className = 'col-12';
                card.innerHTML = `
                    <div class="card review-card shadow-sm p-4">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3 flex-column flex-md-row">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar bg-terracota text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                                    ${review.nombre.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase()}
                                </div>
                                <div>
                                    <h6 class="mb-1">${review.nombre}</h6>
                                    <div class="small text-muted">${renderStars(review.calificacion)} ${formatDate(review.fecha)}</div>
                                </div>
                            </div>
                            <div class="text-end text-success small fw-semibold">${review.verificado ? 'Reseña verificada' : 'Sin verificar'}</div>
                        </div>
                        <p class="mb-0 text-muted">${review.comentario}</p>
                    </div>
                `;
                reviewList.appendChild(card);
            });

            openAllReviews.classList.toggle('d-none', allReviews.length <= 2);
        }

        function renderAllReviews() {
            allReviewList.innerHTML = '';
            allReviews.forEach(review => {
                const card = document.createElement('div');
                card.className = 'col-12';
                card.innerHTML = `
                    <div class="card review-card shadow-sm p-4">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3 flex-column flex-md-row">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar bg-terracota text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 44px; height: 44px;">
                                    ${review.nombre.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase()}
                                </div>
                                <div>
                                    <h6 class="mb-1">${review.nombre}</h6>
                                    <div class="small text-muted">${renderStars(review.calificacion)} ${formatDate(review.fecha)}</div>
                                </div>
                            </div>
                            <div class="text-end text-success small fw-semibold">${review.verificado ? 'Reseña verificada' : 'Sin verificar'}</div>
                        </div>
                        <p class="mb-0 text-muted">${review.comentario}</p>
                        ${review.fotos && review.fotos.length ? `<div class="review-photo-gallery mt-3">${review.fotos.map(url => `<div class="review-photo-thumb"><img src="${url}" alt="Foto reseña" /></div>`).join('')}</div>` : ''}
                    </div>
                `;
                allReviewList.appendChild(card);
            });
        }

        function sortAndRender() {
            const criteria = sortReviews.value;
            if (criteria === 'best') {
                allReviews.sort((a, b) => b.calificacion - a.calificacion || new Date(b.fecha) - new Date(a.fecha));
            } else if (criteria === 'worst') {
                allReviews.sort((a, b) => a.calificacion - b.calificacion || new Date(b.fecha) - new Date(a.fecha));
            } else {
                allReviews.sort((a, b) => new Date(b.fecha) - new Date(a.fecha));
            }
            renderReviews();
            renderAllReviews();
        }

        function setActiveStars(value) {
            starButtons.forEach(button => {
                const starValue = Number(button.dataset.value);
                button.classList.toggle('active', starValue <= value);
            });
            reviewRating.value = value;
        }

        function createFileList(files) {
            const dataTransfer = new DataTransfer();
            files.forEach(file => dataTransfer.items.add(file));
            return dataTransfer.files;
        }

        function appendFiles(existingFiles, newFiles) {
            const dataTransfer = new DataTransfer();
            Array.from(existingFiles).forEach(file => dataTransfer.items.add(file));
            Array.from(newFiles).forEach(file => dataTransfer.items.add(file));
            return dataTransfer.files;
        }

        function openModal(modal) {
            modal.classList.add('show');
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(modal) {
            modal.classList.remove('show');
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        function clearPhotoPreview() {
            selectedFiles = [];
            reviewPhotoPreview.innerHTML = '';
            reviewPhoto.value = '';
            reviewPhoto.files = createFileList(selectedFiles);
        }

        const dropZone = document.getElementById('dropZone');

        openReviewForm.addEventListener('click', () => openModal(newReviewModal));
        closeReviewModal.addEventListener('click', () => {
            closeModal(newReviewModal);
            clearPhotoPreview();
        });
        cancelReview.addEventListener('click', () => {
            closeModal(newReviewModal);
            clearPhotoPreview();
        });
        openAllReviews.addEventListener('click', () => {
            openModal(allReviewsModal);
            sortReviewsModal.value = sortReviews.value;
        });
        closeAllReviewsModal.addEventListener('click', () => closeModal(allReviewsModal));

        newReviewModal.addEventListener('click', event => {
            if (event.target === newReviewModal) {
                closeModal(newReviewModal);
                clearPhotoPreview();
            }
        });
        allReviewsModal.addEventListener('click', event => {
            if (event.target === allReviewsModal) {
                closeModal(allReviewsModal);
            }
        });

        dropZone.addEventListener('click', () => {
            reviewPhoto.value = '';
            reviewPhoto.click();
        });
        dropZone.addEventListener('dragover', event => {
            event.preventDefault();
            dropZone.classList.add('active');
        });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('active'));
        dropZone.addEventListener('drop', event => {
            event.preventDefault();
            dropZone.classList.remove('active');
            const files = Array.from(event.dataTransfer.files).filter(file => file.type.startsWith('image/'));
            if (files.length) {
                selectedFiles = selectedFiles.concat(files);
                reviewPhoto.files = createFileList(selectedFiles);
                renderPhotoPreview(selectedFiles);
            }
        });

        starButtons.forEach(button => {
            button.addEventListener('click', () => {
                setActiveStars(Number(button.dataset.value));
            });
        });

        reviewPhoto.addEventListener('change', function () {
            if (this.files.length) {
                selectedFiles = selectedFiles.concat(Array.from(this.files));
                reviewPhoto.files = createFileList(selectedFiles);
                renderPhotoPreview(selectedFiles);
                reviewPhoto.value = '';
            }
        });

        function renderPhotoPreview(files) {
            reviewPhotoPreview.innerHTML = '';
            if (!files || files.length === 0) {
                return;
            }

            Array.from(files).forEach((file, index) => {
                const url = URL.createObjectURL(file);
                const thumb = document.createElement('div');
                thumb.className = 'review-photo-thumb';
                thumb.innerHTML = `
                    <img src="${url}" alt="Foto ${index + 1}" />
                    <button type="button" aria-label="Eliminar foto" data-index="${index}">&times;</button>
                `;

                thumb.querySelector('button')?.addEventListener('click', () => {
                    selectedFiles.splice(index, 1);
                    reviewPhoto.files = createFileList(selectedFiles);
                    renderPhotoPreview(selectedFiles);
                });

                reviewPhotoPreview.appendChild(thumb);
            });
        }

        newReviewForm.addEventListener('submit', event => {
            const comentario = document.getElementById('reviewComment').value.trim();
            if (!comentario) {
                event.preventDefault();
                alert('Por favor escribe tu reseña antes de publicar.');
                return;
            }
            // Se permite que el formulario haga un POST nativo hacia tu Controller
        });

        sortReviews.addEventListener('change', () => {
            sortReviewsModal.value = sortReviews.value;
            sortAndRender();
        });

        sortReviewsModal.addEventListener('change', () => {
            sortReviews.value = sortReviewsModal.value;
            sortAndRender();
        });
        document.addEventListener('DOMContentLoaded', () => {
            loadReviews();
            setActiveStars(5);
            // Cargar horarios dinámicos
            loadBusinessHours(@Model.BusinessId);
        });

        // Callback global para Google Maps
        window.initBusinessMap = function() {
            const mapLat = @lat;
            const mapLng = @lng;
            const mapContainer = document.getElementById('businessMap');
            
            if (mapLat !== 0 && mapLng !== 0) {
                const position = { lat: parseFloat(mapLat), lng: parseFloat(mapLng) };
                const map = new google.maps.Map(mapContainer, {
                    center: position,
                    zoom: 15,
                    disableDefaultUI: true // Interfaz limpia
                });
                
                new google.maps.Marker({
                    position: position,
                    map: map,
                    title: '@Html.Raw(Model.TradeName)'
                });
            } else {
                mapContainer.innerHTML = '<div class="h-100 d-flex align-items-center justify-content-center text-muted small"><i class="bi bi-geo-alt-fill me-2"></i>Ubicación en mapa no disponible</div>';
            }
        };

        function loadBusinessHours(businessId) {
            fetch(`/api/businesshours/status/${businessId}`)
                .then(response => response.json())
                .then(data => {
                    const container = document.getElementById('businessHoursContainer');
                    if (!container) return;

                    let badgeHtml = '';
                    if (data.isOpen) {
                        const warningClass = data.minutesUntilClose <= 30 ? 'bg-warning text-dark' : 'bg-success text-white';
                        const warningText = data.minutesUntilClose <= 30 ? 
                            `<small class="text-dark fw-bold d-block lh-1 mt-1"><i class="bi bi-exclamation-triangle"></i> Cierra pronto</small>` : 
                            '';
                        
                        badgeHtml = `
                            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                                <div class="card-body ${warningClass} py-2 px-3 d-flex align-items-center gap-2">
                                    <div class="fs-4"><i class="bi bi-check-circle-fill"></i></div>
                                    <div class="lh-sm">
                                        <strong class="d-block" style="font-size: 0.9rem;">Abierto ahora</strong>
                                        <small class="opacity-75" style="font-size: 0.75rem;">Cierra a las ${data.closeTime}</small>
                                        ${warningText}
                                    </div>
                                </div>
                            </div>
                        `;
                    } else {
                        const opensAtText = data.opensAt ? 
                            new Date(data.opensAt).toLocaleString('es-ES', { weekday: 'short', hour: '2-digit', minute: '2-digit' }) :
                            'No disponible';
                        
                        badgeHtml = `
                            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                                <div class="card-body bg-light border py-2 px-3 d-flex align-items-center gap-2">
                                    <div class="fs-4 text-danger"><i class="bi bi-door-closed-fill"></i></div>
                                    <div class="lh-sm">
                                        <strong class="d-block text-dark" style="font-size: 0.9rem;">Cerrado ahora</strong>
                                        <small class="text-muted" style="font-size: 0.75rem;">Abre: ${opensAtText}</small>
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                    container.innerHTML = badgeHtml;
                })
                .catch(error => console.error('Error loading business hours:', error));

            // Cargar tabla de horarios semanales
            fetch(`/api/businesshours/week/${businessId}`)
                .then(response => response.json())
                .then(schedules => {
                    const scheduleContainer = document.getElementById('scheduleContainer');
                    if (!scheduleContainer) return;
                    if (schedules.length === 0) {
                        scheduleContainer.innerHTML = '<div class="alert alert-light text-center border text-muted"><i class="bi bi-calendar-x me-2"></i> Aún no se han registrado horarios de atención.</div>';
                        return;
                    }

                    const dayNames = {
                        'Monday': 'Lunes',
                        'Tuesday': 'Martes',
                        'Wednesday': 'Miércoles',
                        'Thursday': 'Jueves',
                        'Friday': 'Viernes',
                        'Saturday': 'Sábados',
                        'Sunday': 'Domingos'
                    };

                    const dayOrder = { Monday: 1, Tuesday: 2, Wednesday: 3, Thursday: 4, Friday: 5, Saturday: 6, Sunday: 7 };
                    schedules.sort((a, b) => (dayOrder[a.dayOfWeek] || 8) - (dayOrder[b.dayOfWeek] || 8));

                    let html = `
                        <h3 class="fw-bold mb-4"><i class="bi bi-clock me-2 text-terracota"></i> Horarios de Atención</h3>
                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                            <table class="table table-hover mb-0">
                                <thead style="background-color: #f8fafc;">
                                    <tr>
                                        <th class="py-3 px-4 border-bottom-0 text-muted fw-semibold">Día</th>
                                        <th class="py-3 px-4 border-bottom-0 text-muted fw-semibold">Apertura</th>
                                        <th class="py-3 px-4 border-bottom-0 text-muted fw-semibold">Cierre</th>
                                    </tr>
                                </thead>
                                <tbody>
                    `;

                    schedules.forEach(schedule => {
                        const openTime = schedule.openTime.substring(0, 5); // HH:mm
                        const closeTime = schedule.closeTime.substring(0, 5);
                        const dayName = dayNames[schedule.dayOfWeek] || schedule.dayOfWeek;
                        html += `
                            <tr>
                                <td class="fw-semibold px-4 py-3 align-middle text-dark">${dayName}</td>
                                <td class="px-4 py-3 align-middle text-muted">${openTime}</td>
                                <td class="px-4 py-3 align-middle text-muted">${closeTime}</td>
                            </tr>
                        `;
                    });

                    html += `
                                </tbody>
                            </table>
                        </div>
                    `;

                    scheduleContainer.innerHTML = html;
                })
                .catch(error => {
                    console.error('Error loading schedules:', error);
                    const scheduleContainer = document.getElementById('scheduleContainer');
                    if (scheduleContainer) {
                        scheduleContainer.innerHTML = '<div class="alert alert-info"><i class="bi bi-info-circle"></i> No hay horarios registrados</div>';
                    }
                });
        }
    </script>
}
