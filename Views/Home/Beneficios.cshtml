@{
    ViewData["Title"] = "Beneficios Premium - PIN";
}

<section class="hero-section d-flex align-items-center justify-content-center text-center" style="min-height: 40vh;">
    <div class="container-fluid hero-content">
        <span class="badge-custom mb-3">IMPULSA TU NEGOCIO</span>
        <h1 class="hero-title">
            Beneficios de <span class="text-orange">PIN Premium</span>
        </h1>
        <p class="hero-subtitle">
            Lleva tu negocio al siguiente nivel con herramientas exclusivas diseñadas para aumentar tus ventas.
        </p>
    </div>
</section>

<section class="py-5">
    <div class="container px-5 text-center">
        <h3 class="fw-bold mb-4">¿Por qué obtener el plan de pago?</h3>
        <p class="lead mb-5 mx-auto" style="max-width: 800px;">
            Al suscribirte a nuestro plan Premium, desbloquearás funcionalidades avanzadas como <strong>estadísticas detalladas</strong> de tu negocio. 
            Podrás saber exactamente <strong>cuántas personas visitan la página de tu negocio</strong>, permitiéndote medir tu impacto y mejorar tus estrategias para atraer más clientes.
        </p>
        
        <div class="row justify-content-center mb-5">
            <div class="col-md-6 col-lg-5">
                <div class="cta-card text-left" style="background-color: #1a1a1a; padding: 2rem; border-radius: 15px; color: white; text-align: left; position: relative;">
                    <p class="small mb-2" style="color: #ccc;">TUS ESTADÍSTICAS</p>
                    <h6 style="font-weight: 600;">Visibilidad de tu negocio</h6>

                    <div class="progress mt-3" style="height: 8px; background-color: #333;">
                        <div class="progress-bar" style="width: 85%; background-color: var(--main-orange);"></div>
                    </div>

                    <div class="d-flex justify-content-between mt-3">
                        <small class="fw-bold" style="font-size: 1.2rem;">+3,540 clics</small>
                        <small class="text-success fw-bold" style="font-size: 1.1rem;">+12%</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 mb-5">
            <a href="#" class="btn btn-warning btn-lg fw-bold" style="background-color: var(--main-orange); color: white; border: none; padding: 15px 40px; border-radius: 30px; font-size: 1.1rem;">Continuar a pago</a>
        </div>
    </div>
</section>
