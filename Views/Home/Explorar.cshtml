@model IEnumerable<PinAppdePromo.Models.Business>

@section Styles {
    <link rel="stylesheet" href="~/css/explorar.css" asp-append-version="true" />
    <style>
        .hover-transform { transition: transform 0.3s ease, box-shadow 0.3s ease; }
        .hover-transform:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(255, 107, 0, 0.1) !important; border-color: var(--main-orange) !important; }
        .glass-sidebar { background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); border-radius: 20px; border: 1px solid rgba(0,0,0,0.05); }
        .custom-check:checked { background-color: var(--main-orange); border-color: var(--main-orange); }
        .badge-orange-light { background-color: #fff0e6; color: var(--main-orange); }
        .btn-orange-pin { background-color: var(--main-orange); color: white; transition: all 0.2s; }
        .btn-orange-pin:hover { background-color: #e66000; color: white; transform: scale(1.02); }
        .card-negocio { border-radius: 16px; overflow: hidden; border: 1px solid transparent; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .card-negocio:hover { transform: translateY(-8px); box-shadow: 0 20px 40px rgba(0,0,0,0.08) !important; border-color: rgba(255,107,0,0.3); }
        .img-container { overflow: hidden; }
        .img-container img { transition: transform 0.5s ease; }
        .card-negocio:hover .img-container img { transform: scale(1.05); }
        .page-link { color: var(--main-orange); border-radius: 8px; margin: 0 2px; }
        .page-item.active .page-link { background-color: var(--main-orange); border-color: var(--main-orange); }
    </style>
}

<div class="container-fluid mt-4">
    <div class="row">
        <aside class="col-md-3 pe-4">
            <form action="/Home/Explorar" method="get" class="card shadow-sm p-4 glass-sidebar filtro-sidebar mb-4">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-funnel-fill text-warning me-2"></i>Filtros</h5>
                    <a href="/Home/Explorar" class="text-decoration-none small fw-bold" style="color: var(--main-orange);"><i class="bi bi-arrow-counterclockwise"></i> Limpiar</a>
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold">BÚSQUEDA DIRECTA</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="busqueda" value="@Context.Request.Query["busqueda"]" class="form-control bg-light border-start-0" placeholder="Ej. Cevicheria, Taller...">
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold">CATEGORÍAS</label>
                    @if (ViewBag.Categorias != null)
                    {
                        @foreach (var cat in ViewBag.Categorias)
                        {
                            var isChecked = ((List<int>)ViewBag.CategoriasSeleccionadas).Contains((int)cat.CategoryId);
                            <div class="form-check mb-2">
                                <input class="form-check-input custom-check" type="checkbox" name="categorias" value="@cat.CategoryId" id="cat_@cat.CategoryId" @(isChecked ? "checked" : "")>
                                <label class="form-check-label" for="cat_@cat.CategoryId">@cat.Name</label>
                            </div>
                        }
                    }
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold">UBICACIÓN (LIMA)</label>
                    <select name="distrito" class="form-select bg-light">
                        <option value="">Todos los distritos</option>
                        @if (ViewBag.Distritos != null)
                        {
                            @foreach (var dist in ViewBag.Distritos)
                            {
                                <option value="@dist" selected="@(ViewBag.DistritoActual == dist)">@dist</option>
                            }
                        }
                    </select>
                </div>
                
                <input type="hidden" name="orden" id="ordenHidden" value="@ViewBag.OrdenActual" />
                <button type="submit" class="btn w-100 fw-bold text-white mt-2 shadow-sm" style="background-color: var(--main-orange);">Aplicar Filtros</button>
            </form>
        </aside>

        <main class="col-md-9">
            <!-- SECCIÓN RECOMENDADOS (ML) -->
            @if (ViewBag.Recomendaciones != null && ((IEnumerable<PinAppdePromo.ML.NegocioRecomendadoDTO>)ViewBag.Recomendaciones).Any())
            {
                <div class="mb-5">
                    <div class="d-flex align-items-center mb-3">
                        <h4 class="fw-bold mb-0" style="color: var(--main-orange);">Recomendado para ti ✨</h4>
                        <span class="badge bg-warning text-dark ms-2 shadow-sm rounded-pill"><i class="bi bi-lightning-fill text-warning-emphasis"></i> Inteligencia Artificial</span>
                    </div>
                    <div class="row flex-nowrap overflow-auto pb-3" style="scrollbar-width: thin;">
                        @foreach (var item in (IEnumerable<PinAppdePromo.ML.NegocioRecomendadoDTO>)ViewBag.Recomendaciones)
                        {
                            var rec = item.NegocioDTO;
                            <div class="col-10 col-sm-6 col-md-5 col-lg-4">
                                <a href="/Home/InfNegocio/@rec.Id" class="text-decoration-none text-dark">
                                    <div class="card h-100 border-0 shadow-sm transition-transform hover-transform" style="border-radius: 16px; overflow: hidden; border-left: 4px solid var(--main-orange) !important;">
                                        <!-- Imagen o Placeholder -->
                                        <div style="height: 140px; background-color: #f8f9fa;" class="position-relative">
                                            @if (!string.IsNullOrEmpty(rec.ImagenUrl))
                                            {
                                                var imgUrl = rec.ImagenUrl;
                                                if (!imgUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) && !imgUrl.StartsWith("/") && !imgUrl.StartsWith("data:image"))
                                                {
                                                    imgUrl = "/images/businesses/" + imgUrl;
                                                }
                                                <img src="@imgUrl" class="w-100 h-100" style="object-fit: cover;" alt="@rec.Nombre" />
                                            }
                                            else
                                            {
                                                <div class="d-flex align-items-center justify-content-center h-100 w-100" style="background: linear-gradient(135deg, #fce0ce 0%, #fdebd0 100%);">
                                                    <i class="bi bi-shop text-muted" style="font-size: 2rem; opacity: 0.5;"></i>
                                                </div>
                                            }
                                            <div class="position-absolute bottom-0 start-0 w-100 px-2 py-1" style="background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);">
                                                <span class="badge bg-dark mb-1 text-uppercase" style="font-size: 0.65rem;">@rec.Categoria</span>
                                            </div>
                                        </div>
                                        
                                        <div class="card-body p-3">
                                            <h6 class="fw-bold text-truncate mb-1">@rec.Nombre</h6>
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <span class="small text-muted"><i class="bi bi-geo-alt"></i> @(string.IsNullOrEmpty(rec.Direccion) ? "Local" : rec.Direccion)</span>
                                                <span class="badge bg-light text-dark border"><i class="bi bi-star-fill text-warning"></i> @rec.Calificacion.ToString("0.0")</span>
                                            </div>
                                            <!-- Razón por ML -->
                                            <p class="small mb-0 text-muted fst-italic" style="font-size: 0.75rem;"><i class="bi bi-info-circle text-info"></i> @item.Razon</p>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mb-4">
                <p class="text-muted mb-0">Mostrando <span class="fw-bold text-dark">@Model.Count() negocios</span> de <span class="fw-bold text-dark">@ViewBag.TotalItems</span> en total</p>
                <div class="d-flex align-items-center">
                    <span class="me-2 text-muted">Ordenar por:</span>
                    <select id="ordenSelect" class="form-select form-select-sm border-0 fw-bold" style="width: auto; color: var(--main-orange);">
                        <option value="" selected="@(ViewBag.OrdenActual == null)">Relevancia</option>
                        <option value="calificacion" selected="@(ViewBag.OrdenActual == "calificacion")">Calificación</option>
                        <option value="nombre" selected="@(ViewBag.OrdenActual == "nombre")">Nombre A-Z</option>
                    </select>
                </div>
            </div>

            <div class="row g-4">
                @foreach (var negocio in Model)
                {
                    <div class="col-md-6">
                        <div class="card h-100 shadow-sm card-negocio bg-white">
                            <div class="position-relative img-container" style="height: 220px;">
                                @if (negocio.Images != null && negocio.Images.Any())
                                {
                                    var rawUrl = negocio.Images.First().ImageUrl?.Trim();
                                    var imgUrl = rawUrl;
                                    if (!string.IsNullOrEmpty(rawUrl)) {
                                        if (rawUrl.StartsWith("~/")) {
                                            imgUrl = Url.Content(rawUrl);
                                        } else if (!rawUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) && !rawUrl.StartsWith("/") && !rawUrl.StartsWith("data:image")) {
                                            imgUrl = "/images/businesses/" + rawUrl;
                                        }
                                    }
                                        
                                    <img src="@imgUrl" class="card-img-top w-100 h-100" alt="@negocio.TradeName" style="object-fit: cover;" />
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100 w-100" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
                                        <div class="text-center">
                                            <i class="bi bi-image" style="font-size: 3rem; color: #adb5bd; margin-bottom: 8px; display: block;"></i>
                                        </div>
                                    </div>
                                }

                                @if (negocio.Status == "Promoted")
                                {
                                    <span class="badge bg-white text-dark position-absolute top-0 start-0 m-3 shadow px-3 py-2 rounded-pill fw-bold" style="font-size: 0.75rem;"><i class="bi bi-star-fill text-warning"></i> DESTACADO</span>
                                }
                                <div class="position-absolute bottom-0 start-0 w-100 px-3 py-2" style="background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);">
                                    <span class="badge bg-dark mb-1 text-uppercase border border-secondary" style="font-size: 0.7rem;">@(negocio.Category?.Name ?? "General")</span>
                                </div>
                            </div>
                            <div class="card-body p-4 d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title fw-bold text-dark mb-0 text-truncate pe-2">@negocio.TradeName</h5>
                                    <span class="badge bg-light text-dark border shadow-sm px-2 py-1"><i class="bi bi-star-fill text-warning me-1"></i> @(negocio.Reviews != null && negocio.Reviews.Any() ? Math.Round(negocio.Reviews.Average(r => r.Rating), 1).ToString("0.0") : "5.0")</span>
                                </div>
                                <p class="card-text text-muted small mb-2"><i class="bi bi-geo-alt-fill text-secondary me-1"></i> @negocio.Address</p>
                                <p class="card-text text-success small fw-bold mb-4"><i class="bi bi-clock-fill me-1"></i> Abierto ahora</p>
                                
                                <div class="mt-auto row g-2">
                                    <div class="col-7">
                                        <a asp-action="InfNegocio" asp-route-id="@negocio.BusinessId" class="btn btn-orange-pin w-100 py-2 fw-bold rounded-pill shadow-sm">Ver perfil</a>
                                    </div>
                                    <div class="col-5">
                                       <a href="https://www.google.com/maps/search/?api=1&query=@(negocio.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture)),@(negocio.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture))" target="_blank" class="btn btn-light w-100 py-2 fw-bold border text-muted d-block text-center text-decoration-none rounded-pill hover-transform"><i class="bi bi-geo-fill text-primary"></i> Mapa</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
            
            @if (!Model.Any())
            {
                <div class="text-center mt-5 py-5">
                    <i class="bi bi-search display-1 text-muted" style="opacity: 0.3;"></i>
                    <h4 class="mt-3 text-muted">No encontramos negocios</h4>
                    <p class="text-muted">Intenta con otros filtros o términos de búsqueda.</p>
                </div>
            }

            <!-- Paginación -->
            @if (ViewBag.TotalPages > 1)
            {
                <nav aria-label="Paginación" class="mt-5 d-flex justify-content-center">
                    <ul class="pagination">
                        <!-- Botón Anterior -->
                        @if (ViewBag.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Explorar", new { page = ViewBag.CurrentPage - 1, busqueda = ViewBag.BusquedaActual, distrito = ViewBag.DistritoActual, orden = ViewBag.OrdenActual })" aria-label="Anterior">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">&laquo;</span>
                            </li>
                        }

                        <!-- Números de Página -->
                        @{
                            int currentPage = (int)ViewBag.CurrentPage;
                            int totalPages = (int)ViewBag.TotalPages;
                            int maxPagesToShow = 5;
                            int startPage = Math.Max(1, currentPage - maxPagesToShow / 2);
                            int endPage = Math.Min(totalPages, startPage + maxPagesToShow - 1);
                            
                            if (endPage - startPage + 1 < maxPagesToShow) {
                                startPage = Math.Max(1, endPage - maxPagesToShow + 1);
                            }
                        }

                        @if (startPage > 1)
                        {
                            <li class="page-item"><a class="page-link" href="@Url.Action("Explorar", new { page = 1, busqueda = ViewBag.BusquedaActual, distrito = ViewBag.DistritoActual, orden = ViewBag.OrdenActual })">1</a></li>
                            @if (startPage > 2) {
                                <li class="page-item disabled"><span class="page-link border-0 text-muted bg-transparent">...</span></li>
                            }
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            if (i == currentPage)
                            {
                                <li class="page-item active">
                                    <span class="page-link shadow-sm">
                                        @i
                                        <span class="visually-hidden">(página actual)</span>
                                    </span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Explorar", new { page = i, busqueda = ViewBag.BusquedaActual, distrito = ViewBag.DistritoActual, orden = ViewBag.OrdenActual })">
                                        @i
                                    </a>
                                </li>
                            }
                        }

                        @if (endPage < totalPages)
                        {
                            @if (endPage < totalPages - 1) {
                                <li class="page-item disabled"><span class="page-link border-0 text-muted bg-transparent">...</span></li>
                            }
                            <li class="page-item"><a class="page-link" href="@Url.Action("Explorar", new { page = totalPages, busqueda = ViewBag.BusquedaActual, distrito = ViewBag.DistritoActual, orden = ViewBag.OrdenActual })">@totalPages</a></li>
                        }

                        <!-- Botón Siguiente -->
                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Explorar", new { page = ViewBag.CurrentPage + 1, busqueda = ViewBag.BusquedaActual, distrito = ViewBag.DistritoActual, orden = ViewBag.OrdenActual })" aria-label="Siguiente">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">&raquo;</span>
                            </li>
                        }
                    </ul>
                </nav>

                <!-- Info de Paginación -->
                <div class="text-center text-muted mt-3">
                    <small>Mostrando página <strong>@ViewBag.CurrentPage</strong> de <strong>@ViewBag.TotalPages</strong> (Total: <strong>@ViewBag.TotalItems</strong> negocios)</small>
                </div>
            }
        </main>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('ordenSelect').addEventListener('change', function() {
        // Sincronizar con el hidden input del form y enviar
        document.getElementById('ordenHidden').value = this.value;
        document.querySelector('.filtro-sidebar').submit();
    });
</script>
}