@{
    ViewData["Title"] = "PIN - App de Promoción de negocios";
}
@model List<PinAppdePromo.Models.Business>

@section Styles {
    <style>
        /* Custom Colors para Tailwind 2.2 CDN */
        .text-main-orange { color: #ff6b00 !important; }
        .bg-main-orange { background-color: #ff6b00 !important; }
        .bg-orange-light { background-color: #fff0e6 !important; }
        .border-main-orange { border-color: #ff6b00 !important; }
        .hover-text-main-orange:hover { color: #ff6b00 !important; }
        
        .gradient-orange {
            background: linear-gradient(to right, #ff6b00, #ff8c33) !important;
        }
        .text-gradient {
            color: #ff6b00; /* Fallback safe */
            background: -webkit-linear-gradient(#ff6b00, #ff8c33);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .shadow-orange {
            box-shadow: 0 8px 20px rgba(255, 107, 0, 0.3) !important;
        }
        .hover-shadow-orange:hover {
            box-shadow: 0 12px 25px rgba(255, 107, 0, 0.4) !important;
        }

        /* Glassmorphism y utilidades */
        .glass-panel {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }
        .glass-input-container {
            background: rgba(255, 255, 255, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.8);
        }
        .glass-input-container:focus-within {
            border-color: #ff6b00;
        }

        .blob-bg {
            position: absolute;
            filter: blur(80px);
            z-index: -1;
            animation: float 8s ease-in-out infinite;
        }

        .blob-orange {
            background: rgba(255, 107, 0, 0.25);
            width: 500px;
            height: 500px;
            border-radius: 50%;
            top: -100px;
            right: -100px;
        }

        .blob-yellow {
            background: rgba(255, 193, 7, 0.2);
            width: 400px;
            height: 400px;
            border-radius: 50%;
            bottom: -50px;
            left: -100px;
            animation-delay: -4s;
        }

        @@keyframes float {
            0% { transform: translateY(0px) scale(1); }
            50% { transform: translateY(-30px) scale(1.05); }
            100% { transform: translateY(0px) scale(1); }
        }

        .pulse-dot {
            width: 10px;
            height: 10px;
            background-color: #10B981;
            border-radius: 50%;
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
            animation: pulse-green 1.5s infinite cubic-bezier(0.66, 0, 0, 1);
        }

        @@keyframes pulse-green {
            to { box-shadow: 0 0 0 15px rgba(16, 185, 129, 0); }
        }

        .category-btn {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .category-btn:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px -5px rgba(255, 107, 0, 0.2);
            border-color: #ff6b00;
        }
        .category-btn:hover i {
            color: #ff6b00;
            transform: scale(1.1);
        }

        .business-card-modern {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .business-card-modern:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px -5px rgba(255, 107, 0, 0.2);
        }
        .business-card-modern:hover .business-img-modern {
            transform: scale(1.05);
        }

        .cta-card-3d {
            transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            transform: perspective(1000px) rotateY(-5deg) rotateX(5deg);
        }
        .cta-card-3d:hover {
            transform: perspective(1000px) rotateY(0deg) rotateX(0deg) translateY(-10px);
            box-shadow: 0 30px 60px rgba(0,0,0,0.3);
        }
    </style>
}

@if (TempData["Exito"] != null)
{
    <div class="fixed top-24 right-5 z-50 animate-bounce">
        <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-xl shadow-lg flex items-center gap-3">
            <i class="fas fa-check-circle text-green-500"></i>
            <p class="text-sm font-medium">@TempData["Exito"]</p>
            <button onclick="this.parentElement.style.display='none'" class="ml-4 text-green-400 hover:text-green-600">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>
}

<!-- HERO SECTION DINÁMICO -->
<div class="relative bg-gradient-to-b from-orange-100/60 via-[#fffcf7] to-[#fff5eb] pt-24 pb-16 overflow-hidden min-h-[90vh] flex flex-col justify-center">
    
    <!-- Burbujas de colores flotantes de fondo -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden -z-10 pointer-events-none">
        <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-orange-300 rounded-full mix-blend-multiply filter blur-3xl opacity-40 animate-blob"></div>
        <div class="absolute top-[20%] right-[-10%] w-96 h-96 bg-yellow-300 rounded-full mix-blend-multiply filter blur-3xl opacity-40 animate-blob animation-delay-2000"></div>
        <div class="absolute bottom-[-20%] left-[20%] w-[30rem] h-[30rem] bg-orange-200 rounded-full mix-blend-multiply filter blur-3xl opacity-40 animate-blob animation-delay-4000"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10 text-center flex flex-col items-center mt-10">
        
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-orange-light text-main-orange font-bold text-xs uppercase tracking-wider mb-6">
            <i class="fas fa-compass"></i> Descubre lo local
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold text-gray-800 leading-tight mb-6 tracking-tight max-w-4xl">
            Descubre lo mejor <br class="hidden md:block" />
            de tu <span class="text-gradient">distrito</span>
        </h1>

        <p class="text-lg md:text-xl text-gray-600 mb-10 max-w-2xl font-medium leading-relaxed">
            Conectamos el corazón de los negocios peruanos con la comunidad. Encuentra gastronomía, servicios y mucho más, todo cerca de ti.
        </p>

        <!-- Buscador Glassmorfismo -->
        <form action="/Home/Explorar" method="get" class="glass-panel p-3 rounded-3xl md:rounded-full w-full max-w-3xl flex flex-col md:flex-row items-center gap-3 shadow-lg">
            <div class="glass-input-container flex-1 w-full flex items-center gap-3 px-4 py-3 bg-white rounded-2xl md:rounded-full transition-colors">
                <i class="fas fa-search text-gray-400"></i>
                <input type="text" name="busqueda" placeholder="¿Qué estás buscando? (ej. Cevichería)" class="w-full bg-transparent outline-none text-gray-700 placeholder-gray-400 text-sm font-medium" />
            </div>
            <div class="glass-input-container flex-1 w-full flex items-center gap-3 px-4 py-3 bg-white rounded-2xl md:rounded-full transition-colors">
                <i class="fas fa-map-marker-alt text-gray-400"></i>
                <input type="text" name="distrito" placeholder="Distrito (ej. Miraflores)" class="w-full bg-transparent outline-none text-gray-700 placeholder-gray-400 text-sm font-medium" />
            </div>
            <button type="submit" class="w-full md:w-auto px-8 py-3 md:py-4 gradient-orange text-white rounded-2xl md:rounded-full font-bold text-sm uppercase tracking-wide shadow-orange hover-shadow-orange transition-all transform hover:-translate-y-1">
                Buscar <i class="fas fa-arrow-right ml-1"></i>
            </button>
        </form>

        <!-- Categorías Rápidas -->
        <div class="mt-16 w-full max-w-5xl">
            <p class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-6">Explora por categorías</p>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                <a href="/Home/Explorar?busqueda=Restaurantes" class="category-btn bg-white px-6 py-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center gap-3 text-gray-600 hover-text-main-orange">
                    <div class="w-12 h-12 rounded-full bg-orange-light flex items-center justify-center text-main-orange text-xl transition-transform">
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path d="M4 3a2 2 0 100 4h12a2 2 0 100-4H4z" /><path fill-rule="evenodd" d="M3 8h14v7a2 2 0 01-2 2H5a2 2 0 01-2-2V8zm5 3a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1z" clip-rule="evenodd" /></svg>
                    </div>
                    <span class="font-bold text-sm">Restaurantes</span>
                </a>
                <a href="/Home/Explorar?busqueda=Salud" class="category-btn bg-white px-6 py-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center gap-3 text-gray-600 hover:text-green-500">
                    <div class="w-12 h-12 rounded-full bg-green-50 flex items-center justify-center text-green-500 text-xl transition-transform">
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" /></svg>
                    </div>
                    <span class="font-bold text-sm hover:text-green-500">Salud y Belleza</span>
                </a>
                <a href="/Home/Explorar?busqueda=Tecnología" class="category-btn bg-white px-6 py-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center gap-3 text-gray-600 hover:text-blue-500">
                    <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-blue-500 text-xl transition-transform">
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 2a4 4 0 00-4 4v1H5a1 1 0 00-.994.89l-1 9A1 1 0 004 18h12a1 1 0 00.994-1.11l-1-9A1 1 0 0015 7h-1V6a4 4 0 00-4-4zm2 5V6a2 2 0 10-4 0v1h4zm-6 3a1 1 0 112 0 1 1 0 01-2 0zm7-1a1 1 0 100 2 1 1 0 000-2z" clip-rule="evenodd" /></svg>
                    </div>
                    <span class="font-bold text-sm hover:text-blue-500">Tecnología</span>
                </a>
                <a href="/Home/Explorar?busqueda=Automotrices" class="category-btn bg-white px-6 py-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center gap-3 text-gray-600 hover:text-purple-500">
                    <div class="w-12 h-12 rounded-full bg-purple-50 flex items-center justify-center text-purple-500 text-xl transition-transform">
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" /></svg>
                    </div>
                    <span class="font-bold text-sm hover:text-purple-500">Servicios Automotrices</span>
                </a>
            </div>
        </div>

    </div>
</div>

<!-- SECCIÓN CÓMO FUNCIONA -->
<section class="py-20 relative bg-gradient-to-b from-[#fff5eb] to-[#fffcf7] border-t border-b border-orange-100/50">
    <div class="container mx-auto px-6 max-w-7xl relative z-10">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800 tracking-tight mb-3">¿Cómo funciona <span class="text-gradient">PIN</span>?</h2>
            <p class="text-gray-500 text-lg">Descubre, visita y apoya a los mejores negocios locales en 3 simples pasos.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center relative">
            <!-- Línea conectora (solo visible en desktop) -->
            <div class="hidden md:block absolute top-12 left-[15%] right-[15%] h-0.5 bg-gradient-to-r from-orange-100 via-orange-300 to-orange-100 -z-10"></div>

            <!-- Paso 2 -->
            <div class="flex flex-col items-center">
                <div class="w-24 h-24 bg-white rounded-full shadow-[0_10px_30px_rgba(255,107,0,0.15)] flex items-center justify-center mb-6 relative group transition-transform hover:-translate-y-2">
                    <div class="absolute inset-0 rounded-full border-2 border-orange-200 scale-110 opacity-0 group-hover:opacity-100 group-hover:scale-100 transition-all duration-300"></div>
                    <svg class="w-10 h-10 text-main-orange" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                    <div class="absolute -top-2 -right-2 w-8 h-8 bg-gray-900 text-white rounded-full font-bold flex items-center justify-center text-sm shadow-md">2</div>
                </div>
                <h3 class="text-xl font-bold text-gray-800 mb-2">Lee opiniones reales</h3>
                <p class="text-gray-500">Confía en las experiencias y reseñas de nuestra comunidad de usuarios.</p>
            </div>

            <!-- Paso 3 -->
            <div class="flex flex-col items-center">
                <div class="w-24 h-24 bg-white rounded-full shadow-[0_10px_30px_rgba(255,107,0,0.15)] flex items-center justify-center mb-6 relative group transition-transform hover:-translate-y-2">
                    <div class="absolute inset-0 rounded-full border-2 border-orange-200 scale-110 opacity-0 group-hover:opacity-100 group-hover:scale-100 transition-all duration-300"></div>
                    <svg class="w-10 h-10 text-main-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                    <div class="absolute -top-2 -right-2 w-8 h-8 bg-gray-900 text-white rounded-full font-bold flex items-center justify-center text-sm shadow-md">3</div>
                </div>
                <h3 class="text-xl font-bold text-gray-800 mb-2">Comparte y Califica</h3>
                <p class="text-gray-500">Visita el lugar y ayuda a otros dejando tu propia calificación y reseña.</p>
            </div>
        </div>
    </div>
</section>

<!-- SECCIÓN NEGOCIOS DESTACADOS -->
<section class="py-24 bg-[#fffaf5] relative">
    <div class="container mx-auto px-6 max-w-7xl">
        <div class="flex justify-between items-end mb-12">
            <div>
                <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800 tracking-tight mb-2">Negocios <span class="text-gradient">Destacados</span></h2>
                <p class="text-gray-500 text-lg">Los lugares favoritos de la comunidad esta semana.</p>
            </div>
            <a href="/Home/Explorar" class="hidden md:flex items-center gap-2 text-main-orange font-bold hover:text-orange-700 transition-colors">
                Ver todos <i class="fas fa-arrow-right"></i>
            </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            @foreach (var negocio in Model.Take(8))
            {
                <a href="/Home/InfNegocio/@negocio.BusinessId" class="block group">
                    <div class="business-card-modern bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm h-full flex flex-col">
                        
                        <div class="relative overflow-hidden h-48">
                            <img src="@(negocio.Images?.FirstOrDefault()?.ImageUrl ?? "https://images.unsplash.com/photo-1559314809-0d155014e29e?w=800&q=80")" 
                                 class="business-img-modern w-full h-full object-cover transition-transform duration-500" 
                                 alt="@negocio.TradeName">
                            
                            <!-- Etiqueta Flotante Abierto -->
                            <div class="absolute top-4 left-4 bg-white px-3 py-1.5 rounded-full shadow-sm flex items-center gap-2" style="background: rgba(255,255,255,0.9);">
                                <div class="pulse-dot"></div>
                                <span class="text-xs font-bold tracking-wide text-gray-700 uppercase">Abierto</span>
                            </div>

                            <!-- Categoría flotante -->
                            <div class="absolute bottom-4 right-4 bg-gray-900 px-3 py-1 rounded-lg text-white text-xs font-semibold" style="background: rgba(17, 24, 39, 0.8);">
                                @(negocio.Category?.Name ?? "General")
                            </div>
                        </div>

                        <div class="p-5 flex-1 flex flex-col">
                            <h3 class="text-lg font-bold text-gray-800 mb-1 hover-text-main-orange transition-colors line-clamp-1">@negocio.TradeName</h3>
                            
                            <div class="flex items-start gap-2 text-gray-500 text-sm mb-4 flex-1">
                                <i class="fas fa-map-marker-alt mt-1 text-gray-400"></i>
                                <span class="line-clamp-2 leading-relaxed">@negocio.Address</span>
                            </div>

                            <div class="pt-4 border-t border-gray-50 flex items-center justify-between">
                                <div class="flex items-center gap-1 text-yellow-400 font-bold">
                                    <i class="fas fa-star"></i>
                                    <span class="text-gray-700">@(negocio.Reviews != null && negocio.Reviews.Any() ? Math.Round(negocio.Reviews.Average(r => r.Rating), 1).ToString("0.0") : "5.0")</span>
                                    <span class="text-gray-400 text-xs font-medium ml-1">(@(negocio.Reviews?.Count ?? 0))</span>
                                </div>
                                <span class="text-main-orange text-sm font-semibold group-hover:translate-x-1 transition-transform">Ver perfil <i class="fas fa-angle-right ml-1"></i></span>
                            </div>
                        </div>

                    </div>
                </a>
            }
        </div>
    </div>
</section>

<!-- SECCIÓN CALL TO ACTION (ÚNETE) -->
<section class="py-24 bg-gray-900 text-white relative overflow-hidden shadow-[0_-10px_40px_rgba(255,107,0,0.15)]">
    <!-- Círculos decorativos de fondo -->
    <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-gradient-to-br from-[#ff6b00] to-orange-600 rounded-full blur-3xl opacity-20 translate-x-1/3 -translate-y-1/3"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-yellow-500 rounded-full blur-3xl opacity-10 -translate-x-1/2 translate-y-1/2"></div>
    
    <div class="container mx-auto px-6 max-w-7xl relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            
            <div class="text-white">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white text-main-orange font-bold text-xs uppercase tracking-wider mb-6" style="background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2);">
                    <i class="fas fa-rocket"></i> Potencia tus ventas
                </div>
                <h2 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">
                    ¿Tienes un negocio? <br />
                    Hazlo crecer con <span class="text-gradient">nosotros.</span>
                </h2>
                <p class="text-gray-300 text-lg mb-10 leading-relaxed max-w-xl">
                    Únete a la red más grande de negocios locales en Perú y llega a miles de clientes potenciales en tu distrito hoy mismo. Incrementa tu visibilidad y facilita el contacto con nuevos clientes.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a asp-controller="Login" asp-action="Index" class="px-8 py-4 bg-main-orange hover-bg-main-orange text-white rounded-xl font-bold transition-all shadow-orange hover-shadow-orange transform hover:-translate-y-1">
                        Comenzar gratis
                    </a>
                    <a asp-controller="Home" asp-action="Beneficios" class="px-8 py-4 border border-white text-white rounded-xl font-bold transition-all" style="background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2);">
                        Saber más
                    </a>
                </div>
            </div>

            <div class="relative flex justify-center lg:justify-end">
                <!-- Tarjeta 3D -->
                <div class="cta-card-3d bg-white p-8 rounded-3xl shadow-2xl w-full max-w-sm relative z-20 border border-gray-100">
                    <div class="w-12 h-12 bg-orange-light rounded-2xl flex items-center justify-center text-main-orange text-2xl mb-6 shadow-inner">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-1">Tus Estadísticas</p>
                    <h6 class="text-2xl font-extrabold text-gray-800 mb-6">Visibilidad este mes</h6>
                    
                    <div class="h-3 w-full bg-gray-100 rounded-full overflow-hidden mb-4 shadow-inner">
                        <div class="h-full gradient-orange w-3/4 rounded-full relative">
                            <div class="absolute top-0 right-0 bottom-0 w-8 animate-pulse" style="background: rgba(255,255,255,0.3);"></div>
                        </div>
                    </div>
                    
                    <div class="flex justify-between items-center border-t border-gray-100 pt-4 mt-2">
                        <div>
                            <p class="text-3xl font-black text-gray-800">+1,240</p>
                            <p class="text-xs font-semibold text-gray-500 uppercase">Visitas nuevas</p>
                        </div>
                        <div class="bg-green-100 text-green-600 px-3 py-1.5 rounded-lg text-sm font-bold flex items-center gap-1">
                            <i class="fas fa-arrow-up"></i> 24%
                        </div>
                    </div>
                </div>

                <!-- Decoración detrás de la tarjeta -->
                <div class="absolute top-10 -right-4 w-full max-w-sm h-full gradient-orange rounded-3xl opacity-20 z-10" style="filter: blur(40px);"></div>
            </div>

        </div>
    </div>
</section>

<!-- SECCIÓN TESTIMONIOS (De la Base de Datos) -->
<section class="py-24 bg-[#fffcf7] overflow-hidden border-t border-orange-100/30">
    <div class="container mx-auto px-6 max-w-7xl">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800 tracking-tight mb-4">Lo que dicen nuestros clientes</h2>
            <p class="text-gray-500 text-lg max-w-2xl mx-auto">Experiencias reales de personas que ya conectaron con los mejores negocios de su distrito.</p>
        </div>

        <!-- Contenedor Scroll Snap (Carrusel CSS) -->
        <div class="flex overflow-x-auto gap-6 pb-8 snap-x snap-mandatory hide-scrollbar" style="-ms-overflow-style: none; scrollbar-width: none;">
            <style>
                .hide-scrollbar::-webkit-scrollbar { display: none; }
            </style>

            @if (ViewBag.ResenasRecientes != null && ((IEnumerable<PinAppdePromo.Models.Review>)ViewBag.ResenasRecientes).Any())
            {
                foreach (var review in (IEnumerable<PinAppdePromo.Models.Review>)ViewBag.ResenasRecientes)
                {
                    <div class="snap-center shrink-0 w-80 md:w-96 bg-white p-8 rounded-3xl shadow-sm border border-gray-100 flex flex-col justify-between transition-transform hover:-translate-y-2 duration-300">
                        <div>
                            <div class="flex text-yellow-400 text-sm mb-4">
                                @for (int i = 0; i < 5; i++)
                                {
                                    if (i < review.Rating)
                                    {
                                        <i class="fas fa-star"></i>
                                    }
                                    else
                                    {
                                        <i class="far fa-star text-gray-300"></i>
                                    }
                                }
                            </div>
                            <p class="text-gray-600 font-medium leading-relaxed italic mb-6">"@review.Comment"</p>
                        </div>
                        <div class="flex items-center gap-4">
                            <img src="@(string.IsNullOrEmpty(review.User?.ProfilePic) ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(review.User?.FullName ?? "User") + "&background=ff6b00&color=fff" : review.User.ProfilePic)" class="w-12 h-12 rounded-full object-cover shadow-sm" alt="@(review.User?.FullName ?? "Usuario")" />
                            <div>
                                <h4 class="font-bold text-gray-800 text-sm">@(review.User?.FullName ?? "Usuario Anónimo")</h4>
                                <p class="text-xs text-gray-400 line-clamp-1">Sobre @(review.Business?.TradeName ?? "un negocio")</p>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="w-full text-center py-10 text-gray-400 font-medium">
                    Aún no hay reseñas recientes. ¡Sé el primero en compartir tu experiencia!
                </div>
            }

        </div>
    </div>
</section>