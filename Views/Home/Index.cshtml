@{
    ViewData["Title"] = "PIN - App de Promoción de negocios";
}
@model List<Pin___App_de_Promoci_n_de_negocios.Models.Negocio>

<section class="hero-section d-flex align-items-center justify-content-center text-center">
    <div class="container-fluid">

        <span class="badge-custom mb-3">DESCUBRE LO LOCAL</span>

        <h1 class="hero-title">
            Descubre lo mejor <br>
            de tu <span class="text-orange">distrito</span>
        </h1>

        <p class="hero-subtitle">
            Conectamos el corazón de los negocios peruanos con la comunidad.
            Encuentra desde la mejor gastronomía hasta servicios especializados cerca de ti.
        </p>

        <div class="search-box mx-auto mt-4">
            <input type="text" placeholder="¿Qué estás buscando?" class="input-search">
            <input type="text" placeholder="Distrito" class="input-location">
            <button class="btn-search">Buscar →</button>
        </div>

    </div>
</section>

<section class="featured-section py-5">
    <div class="container-fluid px-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold">Negocios destacados</h4>
            <a href="#" class="see-all">Ver todos ></a>
        </div>

        <div class="row g-4">

            @foreach (var negocio in Model.Where(n => n.Destacado))
            {
                <div class="col-md-3">
                    <div class="business-card">

                        <img src="@negocio.ImagenUrl" class="business-img">

                        <div class="p-3">

                            <h6 class="business-title">@negocio.Nombre</h6>

                            <p class="business-category">@negocio.Categoria</p>

                            <small class="business-location">
                                📍 @negocio.Direccion
                            </small>

                            <div class="mt-2">
                                ⭐ @negocio.Calificacion
                            </div>

                            <div>
                                @if (negocio.EstaAbierto)
                                {
                                    <span class="badge bg-success">Abierto</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Cerrado</span>
                                }
                            </div>

                        </div>

                    </div>
                </div>
            }

        </div>

    </div>
</section>