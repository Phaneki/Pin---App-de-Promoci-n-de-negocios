@{
    ViewData["Title"] = "Nosotros";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-orange">Sobre Nosotros</h1>
        <p class="lead text-muted">Conectando negocios con personas, creando valor en cada interacción.</p>
    </div>

    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h2 class="fw-bold mb-3">Nuestra Misión</h2>
            <p class="fs-5 text-secondary">
                En PinApp, nuestra misión es democratizar la promoción de negocios locales, brindándoles herramientas de primer nivel para llegar a más clientes. Creemos en el poder del comercio local y en su impacto en la comunidad.
            </p>
        </div>
        <div class="col-md-6 text-center">
            <i class="fas fa-rocket fa-5x" style="color: #ff6b00;"></i>
        </div>
    </div>

    <div class="row align-items-center flex-md-row-reverse mb-5">
        <div class="col-md-6">
            <h2 class="fw-bold mb-3">Nuestra Visión</h2>
            <p class="fs-5 text-secondary">
                Ser la plataforma líder en el descubrimiento y promoción de negocios, donde cualquier usuario pueda encontrar exactamente lo que necesita de forma rápida, segura y confiable.
            </p>
        </div>
        <div class="col-md-6 text-center">
            <i class="fas fa-eye fa-5x" style="color: #ff6b00;"></i>
        </div>
    </div>
</div>
