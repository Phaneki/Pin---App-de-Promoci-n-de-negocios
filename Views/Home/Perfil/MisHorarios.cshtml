@{
    ViewData["Title"] = "Gestionar Horarios";
}

<div class="container my-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2 class="mb-4">
                <i class="bi bi-clock"></i> Mis Horarios de Atención
            </h2>

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Message"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-sm">
                <div class="card-body">
                    <p class="text-muted mb-4">
                        <i class="bi bi-info-circle"></i> Registra tu horario de atención para que los clientes sepan cuándo estás abierto.
                    </p>

                    <form id="scheduleForm" method="post">
                        <div class="table-responsive">
                            <table class="table table-borderless">
                                <thead class="table-light">
                                    <tr>
                                        <th>Día</th>
                                        <th>¿Abierto?</th>
                                        <th>Hora Apertura</th>
                                        <th>Hora Cierre</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        string[] days = { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
                                        string[] dayNames = { "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábados", "Domingos" };

                                        for (int i = 0; i < days.Length; i++)
                                        {
                                            <tr>
                                                <td class="fw-semibold">@dayNames[i]</td>
                                                <td>
                                                    <input type="checkbox" class="form-check-input dayCheck" value="@days[i]" data-day="@days[i]">
                                                </td>
                                                <td>
                                                    <input type="time" class="form-control form-control-sm openTime" data-day="@days[i]" disabled>
                                                </td>
                                                <td>
                                                    <input type="time" class="form-control form-control-sm closeTime" data-day="@days[i]" disabled>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-4">
                            <button type="button" class="btn btn-primary me-2" onclick="saveSchedules()">
                                <i class="bi bi-check-circle me-2"></i>Guardar Horarios
                            </button>
                            <a href="/Home/Perfil" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Volver
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const dayCheckboxes = document.querySelectorAll('.dayCheck');

    // Habilitar/deshabilitar inputs según checkbox
    dayCheckboxes.forEach(checkbox => {
        checkbox.addEventListener('change', function () {
            const day = this.dataset.day;
            const openInput = document.querySelector(`.openTime[data-day="${day}"]`);
            const closeInput = document.querySelector(`.closeTime[data-day="${day}"]`);
            
            if (this.checked) {
                openInput.disabled = false;
                closeInput.disabled = false;
                // Valores por defecto
                if (!openInput.value) openInput.value = '09:00';
                if (!closeInput.value) closeInput.value = '18:00';
            } else {
                openInput.disabled = true;
                closeInput.disabled = true;
                openInput.value = '';
                closeInput.value = '';
            }
        });
    });

    // Cargar horarios existentes desde API
    async function loadSchedules() {
        const businessId = @Model?.BusinessId ?? 0; // Reemplazar con el ID del negocio del usuario
        if (businessId === 0) return;

        try {
            const response = await fetch(`/api/businesshours/week/${businessId}`);
            const schedules = await response.json();

            schedules.forEach(schedule => {
                const checkbox = document.querySelector(`.dayCheck[data-day="${schedule.dayOfWeek}"]`);
                const openInput = document.querySelector(`.openTime[data-day="${schedule.dayOfWeek}"]`);
                const closeInput = document.querySelector(`.closeTime[data-day="${schedule.dayOfWeek}"]`);

                if (checkbox && openInput && closeInput) {
                    checkbox.checked = true;
                    openInput.disabled = false;
                    closeInput.disabled = false;
                    openInput.value = schedule.openTime.substring(0, 5); // HH:mm
                    closeInput.value = schedule.closeTime.substring(0, 5);
                }
            });
        } catch (error) {
            console.error('Error loading schedules:', error);
        }
    }

    // Guardar horarios
    async function saveSchedules() {
        const businessId = @Model?.BusinessId ?? 0;
        if (businessId === 0) {
            alert('No se encontró el ID del negocio');
            return;
        }

        const schedules = [];
        dayCheckboxes.forEach(checkbox => {
            if (checkbox.checked) {
                const day = checkbox.dataset.day;
                const openTime = document.querySelector(`.openTime[data-day="${day}"]`).value;
                const closeTime = document.querySelector(`.closeTime[data-day="${day}"]`).value;

                if (!openTime || !closeTime) {
                    alert(`Por favor completa los horarios para ${day}`);
                    return;
                }

                schedules.push({
                    dayOfWeek: day,
                    openTime: openTime,
                    closeTime: closeTime
                });
            }
        });

        if (schedules.length === 0) {
            alert('Por favor selecciona al menos un día');
            return;
        }

        try {
            const response = await fetch('/api/businesshours/save', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    businessId: businessId,
                    schedules: schedules
                })
            });

            if (response.ok) {
                alert('¡Horarios guardados exitosamente!');
                window.location.href = '/Home/Perfil';
            } else {
                const error = await response.json();
                alert('Error: ' + error.error);
            }
        } catch (error) {
            console.error('Error saving schedules:', error);
            alert('Ocurrió un error al guardar los horarios');
        }
    }

    // Cargar horarios al abrir la página
    loadSchedules();
</script>
