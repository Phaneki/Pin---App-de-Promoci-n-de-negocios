@{
    ViewData["Title"] = "Contacto";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold mb-3" style="color: #ff6b00;">Contáctanos</h1>
        <p class="lead text-muted">¿Tienes alguna duda o sugerencia? Estamos aquí para ayudarte.</p>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4 p-md-5">
                    <h3 class="fw-bold mb-4">Envíanos un mensaje</h3>
                    
                    @if (TempData["MensajeExito"] != null)
                    {
                        <div class="alert alert-success">@TempData["MensajeExito"]</div>
                    }
                    @if (TempData["MensajeError"] != null)
                    {
                        <div class="alert alert-danger">@TempData["MensajeError"]</div>
                    }

                    <form asp-action="EnviarMensaje" asp-controller="Home" method="post">
                        <div class="mb-3">
                            <label for="nombre" class="form-label">Nombre Completo</label>
                            <input type="text" name="nombre" class="form-control" id="nombre" placeholder="Tu nombre" required>
                        </div>
                        <div class="mb-3">
                            <label for="email" class="form-label">Correo Electrónico</label>
                            <input type="email" name="email" class="form-control" id="email" placeholder="tu@email.com" required>
                        </div>
                        <div class="mb-3">
                            <label for="asunto" class="form-label">Asunto</label>
                            <input type="text" name="asunto" class="form-control" id="asunto" placeholder="¿En qué te ayudamos?" required>
                        </div>
                        <div class="mb-4">
                            <label for="mensaje" class="form-label">Mensaje</label>
                            <textarea name="mensaje" class="form-control" id="mensaje" rows="5" placeholder="Escribe tu mensaje aquí..." required></textarea>
                        </div>
                        <button type="submit" class="btn text-white w-100 py-2 fw-bold" style="background-color: #ff6b00;">Enviar Mensaje</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 h-100" style="background-color: #f8f9fa;">
                <div class="card-body p-4 p-md-5">
                    <h3 class="fw-bold mb-4">Información de Contacto</h3>
                    
                    <div class="d-flex align-items-center mb-4">
                        <div class="rounded-circle bg-white d-flex align-items-center justify-content-center shadow-sm" style="width: 60px; height: 60px;">
                            <i class="fas fa-map-marker-alt fs-4" style="color: #ff6b00;"></i>
                        </div>
                        <div class="ms-4">
                            <h5 class="mb-1 fw-bold">Nuestra Oficina</h5>
                            <p class="mb-0 text-secondary">Av. Javier Prado Este 1234, San Isidro, Lima</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="rounded-circle bg-white d-flex align-items-center justify-content-center shadow-sm" style="width: 60px; height: 60px;">
                            <i class="fas fa-envelope fs-4" style="color: #ff6b00;"></i>
                        </div>
                        <div class="ms-4">
                            <h5 class="mb-1 fw-bold">Correo Electrónico</h5>
                            <p class="mb-0 text-secondary">diego_aliaga@usmp.pe</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="rounded-circle bg-white d-flex align-items-center justify-content-center shadow-sm" style="width: 60px; height: 60px;">
                            <i class="fas fa-phone fs-4" style="color: #ff6b00;"></i>
                        </div>
                        <div class="ms-4">
                            <h5 class="mb-1 fw-bold">Teléfono</h5>
                            <p class="mb-0 text-secondary">+51 987 654 321</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
