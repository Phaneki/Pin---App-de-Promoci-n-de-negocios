<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PinAppdePromo</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PinAppdePromo.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg bg-white border-bottom shadow-sm">
            <div class="container-fluid px-4">

                <!-- LOGO -->
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="logo" style="height:40px;" class="me-2">
                </a>

                <!-- BOTÓN RESPONSIVE -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- CONTENIDO -->
                <div class="collapse navbar-collapse" id="navbarNav">

                    <!-- CENTRO -->
                    <ul class="navbar-nav mx-auto fw-semibold">
                        <li class="nav-item">
                            <a class="nav-link active-custom" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Explorar">Explorar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Categorías</a>
                        </li>
                    </ul>

                    <!-- DERECHA -->
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item">
                            <a asp-controller="Login" asp-action="Index" class="btn btn-outline-dark">
                                Iniciar sesión
                            </a>
                        </li>
                        <li class="nav-item ms-2">
                            <a asp-controller="Home" asp-action="Registrar_negocio" class="btn btn-orange">
                                Registrar negocio
                            </a>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer-custom">
        <div class="container-fluid px-5">

            <div class="row align-items-center text-center text-md-start">

                <!-- IZQUIERDA -->
                <div class="col-md-6 mb-3 mb-md-0">
                    <p class="mb-0 fw-semibold">© 2026 Pin</p>
                    <small class="text-muted">Todos los derechos reservados.</small>
                </div>

                <!-- DERECHA -->
                <div class="col-md-6 text-md-end">
                    <div class="footer-links">
                        <a href="#">Nosotros</a>
                        <a href="#">Privacidad</a>
                        <a href="#">Contacto</a>
                    </div>
                </div>

            </div>

        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
