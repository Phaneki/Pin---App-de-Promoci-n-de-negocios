<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PinAppdePromo</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/infnegocio.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/Pin___App_de_Promoci_n_de_negocios.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PinAppdePromo.styles.css" asp-append-version="true" />
    <style>
        /* Estilos Modernos del Navbar */
        .nav-link-modern {
            position: relative;
            font-weight: 600;
            color: #4b5563 !important;
            padding: 0.5rem 1rem !important;
            transition: color 0.3s ease;
        }
        .nav-link-modern:hover, .nav-link-modern.active-custom {
            color: #ff6b00 !important;
            border-bottom: none !important;
        }
        .nav-link-modern::after {
            content: '';
            position: absolute;
            width: 0%;
            height: 3px;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            background-color: #ff6b00;
            transition: width 0.3s ease;
            border-radius: 3px 3px 0 0;
        }
        .nav-link-modern:hover::after, .nav-link-modern.active-custom::after {
            width: 80%;
        }
        .btn-modern-login {
            border-radius: 9999px !important;
            font-weight: 600 !important;
            padding: 0.5rem 1.5rem !important;
            border: 2px solid #e5e7eb !important;
            transition: all 0.3s ease !important;
            color: #374151 !important;
        }
        .btn-modern-login:hover {
            border-color: #111827 !important;
            background-color: #111827 !important;
            color: white !important;
        }
        .btn-modern-orange {
            border-radius: 9999px !important;
            font-weight: 600 !important;
            padding: 0.5rem 1.5rem !important;
            background: linear-gradient(135deg, #ff6b00, #ff8c33) !important;
            border: none !important;
            color: white !important;
            box-shadow: 0 4px 15px rgba(255, 107, 0, 0.3) !important;
            transition: all 0.3s ease !important;
        }
        .btn-modern-orange:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 107, 0, 0.4) !important;
            color: white !important;
        }
        .dropdown-modern {
            border-radius: 1rem !important;
            border: 1px solid rgba(229,231,235,0.5) !important;
            box-shadow: 0 10px 40px -10px rgba(0,0,0,0.1) !important;
            animation: dropdownFade 0.2s ease-out;
            padding: 0.5rem !important;
        }
        .dropdown-modern .dropdown-item {
            border-radius: 0.5rem;
            padding: 0.5rem 1rem;
            font-weight: 500;
            transition: all 0.2s;
        }
        .dropdown-modern .dropdown-item:hover {
            background-color: #fffaf5;
            color: #ff6b00;
        }
        .dropdown-modern .text-danger:hover {
            background-color: #fef2f2;
            color: #dc2626 !important;
        }
        @@keyframes dropdownFade {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@media (min-width: 992px) {
            .navbar-center-absolute {
                position: absolute;
                left: 50%;
                transform: translateX(-50%);
                z-index: 10;
            }
        }
        /* Fix Tailwind conflict with Bootstrap's collapse */
        .navbar-collapse.collapse {
            visibility: visible !important;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>

<body>
    <div class="modal fade" id="welcomeModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-center p-4 rounded-4">

                <h4 class="mb-3">👋 Bienvenido</h4>

                <p id="welcomeText" class="mb-4"></p>

                <a href="/Home/Perfil" class="btn btn-orange mb-2">Ir al perfil</a>

                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Cerrar
                </button>

            </div>
        </div>
    </div>
    <header>
        @{
        var usuario = Context.Session.GetString("Usuario"); // Esto guarda el correo
        var rol = Context.Session.GetString("Rol");
        var nombreReal = Context.Session.GetString("Nombre");
        var nombreMostrar = !string.IsNullOrEmpty(nombreReal) ? nombreReal : (usuario?.Split('@')[0] ?? "");
    }
        <nav class="navbar navbar-expand-lg sticky-top z-50 transition-all duration-300" style="background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid rgba(229,231,235,0.5); box-shadow: 0 4px 30px rgba(0,0,0,0.03);">
            <div class="container-fluid px-4 py-1">

                <!-- LOGO -->
                <a class="navbar-brand d-flex align-items-center transition-transform hover:scale-105" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="logo" style="height:45px;" class="me-2">
                </a>

                <!-- BOTÓN RESPONSIVE -->
                <button class="navbar-toggler border-0 focus:ring-2 focus:ring-orange-200 rounded-lg" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- CONTENIDO -->
                <div class="collapse navbar-collapse" id="navbarNav">

                    <!-- CENTRO -->
                    <ul class="navbar-nav navbar-center-absolute gap-2 mt-3 mt-lg-0">
                        <li class="nav-item">
                            <a class="nav-link nav-link-modern" id="navInicio" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-modern" id="navExplorar" asp-controller="Home" asp-action="Explorar">Explorar</a>
                        </li>
                    </ul>

                    <!-- DERECHA -->
                    <ul class="navbar-nav ms-auto align-items-center gap-3 mt-4 mt-lg-0">

                        @if (usuario == null)
                        {
                            <li class="nav-item">
                                <a asp-controller="Login" asp-action="Index" class="btn btn-modern-login">
                                    Iniciar sesión
                                </a>
                            </li>
                        }
                        else
                        {
                            @if (usuario != null)
                            {
                                <li class="nav-item">
                                    <a asp-controller="Home" asp-action="RegistrarNegocio" class="btn btn-modern-orange">
                                        Registrar negocio
                                    </a>
                                </li>
                            }

                            @if (rol == "MODERADOR")
                            {
                                <li class="nav-item">
                                    <a asp-controller="Home" asp-action="Moderacion" class="btn rounded-pill fw-bold px-4" style="background-color: #27272a; color: white; border: 2px solid #27272a;">
                                        Manager
                                    </a>
                                </li>
                            }

                            <li class="nav-item dropdown ms-lg-2">

                                <a class="nav-link p-0 dropdown-toggle-hide" href="#" role="button" data-bs-toggle="dropdown">
                                    @if (!string.IsNullOrEmpty(Context.Session.GetString("Foto")))
                                    {
                                        <img src="@Context.Session.GetString("Foto")" class="avatar-img shadow-sm hover:ring-4 ring-orange-100 transition-all" style="width: 42px; height: 42px;" referrerpolicy="no-referrer"  />
                                    }
                                    else
                                    {
                                        <div class="avatar-circle shadow-sm hover:ring-4 ring-orange-100 transition-all" style="width: 42px; height: 42px;">
                                            @nombreMostrar.Substring(0,1).ToUpper()
                                        </div>
                                    }
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end dropdown-modern mt-3">
                                    <li>
                                        <div class="px-3 py-2 border-bottom mb-2 text-center">
                                            <p class="mb-0 fw-bold text-gray-800">Hola, @nombreMostrar</p>
                                            <small class="text-gray-400">@rol</small>
                                        </div>
                                    </li>
                                    <li>
                                        <a class="dropdown-item flex items-center gap-2" asp-controller="Home" asp-action="Perfil">
                                            <i class="fas fa-user-circle text-gray-400"></i> Mi Perfil
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item text-danger flex items-center gap-2 mt-1"
                                        asp-controller="Login"
                                        asp-action="Logout"
                                        onclick="sessionStorage.removeItem('bienvenidaMostrada')">
                                            <i class="fas fa-sign-out-alt"></i> Cerrar sesión
                                        </a>
                                    </li>

                                </ul>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>

    <footer class="mt-auto py-12" style="background: linear-gradient(to right, #ff6b00, #ff8c33);">
        <div class="container mx-auto px-6 max-w-7xl">
            <div class="flex flex-col md:flex-row justify-between items-center gap-6 text-white">
                <!-- IZQUIERDA -->
                <div class="text-center md:text-left">
                    <div class="flex items-center justify-center md:justify-start gap-2 mb-2">
                        <i class="fas fa-map-marker-alt text-2xl"></i>
                        <span class="font-extrabold text-2xl tracking-tight">PIN</span>
                    </div>
                    <p class="text-orange-100 text-sm opacity-90">© 2026 Todos los derechos reservados.</p>
                </div>

                <!-- DERECHA -->
                <div class="flex flex-wrap justify-center items-center gap-6 text-sm font-medium">
                    <a asp-controller="Home" asp-action="Nosotros" class="text-white hover:text-orange-200 transition-colors hover:underline underline-offset-4">Nosotros</a>
                    <a asp-controller="Home" asp-action="Privacidad" class="text-white hover:text-orange-200 transition-colors hover:underline underline-offset-4">Privacidad</a>
                    <a asp-controller="Home" asp-action="Contacto" class="text-white hover:text-orange-200 transition-colors hover:underline underline-offset-4">Contacto</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            var usuarioEmail = '@Context.Session.GetString("Usuario")';
            var nombreReal = '@Context.Session.GetString("Nombre")';
            var nombreAMostrar = nombreReal ? nombreReal : (usuarioEmail ? usuarioEmail.split('@@')[0] : '');

            // bandera para evitar que salga siempre
            if (usuarioEmail && sessionStorage.getItem("bienvenidaMostrada") !== "true") {

                document.getElementById("welcomeText").innerText =
                    "Hola, " + nombreAMostrar;

                var modal = new bootstrap.Modal(document.getElementById('welcomeModal'));
                modal.show();

                sessionStorage.setItem("bienvenidaMostrada", "true");
            }

            // Detectar página actual y aplicar clase active-custom
            var currentPath = window.location.pathname.toLowerCase();
            var navInicio = document.getElementById('navInicio');
            var navExplorar = document.getElementById('navExplorar');

            // Remover clase activa de ambos
            if (navInicio) navInicio.classList.remove('active-custom');
            if (navExplorar) navExplorar.classList.remove('active-custom');

            // Aplicar clase activa según la ruta actual
            if (currentPath.includes('/home/explorar') || currentPath.includes('/explorar')) {
                if (navExplorar) navExplorar.classList.add('active-custom');
            } else {
                if (navInicio) navInicio.classList.add('active-custom');
            }
        });
    </script>
</body>
</html>
