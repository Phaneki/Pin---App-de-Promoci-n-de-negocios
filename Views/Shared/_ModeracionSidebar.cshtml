@{
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
}

<aside class='fixed inset-y-0 left-0 w-72 p-6 shadow-2xl admin-sidebar overflow-y-auto'>
    <!-- Logo y Título -->
    <div class='mb-12 flex items-center gap-4'>
        <div class='flex h-14 w-14 items-center justify-center rounded-2xl bg-white shadow-lg p-2'>
            <img src="~/images/logo.png" alt="Pin Logo" class="h-full w-full object-contain" />
        </div>
        <div>
            <p class='text-xs font-bold uppercase tracking-[0.25em] text-white/80 mb-0.5'>Pin Admin</p>
            <p class='text-2xl font-bold tracking-tight text-white'>Moderación</p>
        </div>
    </div>
    
    <!-- Menú de Navegación -->
    <nav class='space-y-2 text-[15px] font-medium'>
        <a href='/Home/Moderacion' class='nav-item group flex items-center gap-4 rounded-xl px-4 py-3.5 transition-all @(currentAction == "Moderacion" ? "active" : "")'>
            <i class='fas fa-tachometer-alt transition group-hover:text-white text-lg w-6 text-center'></i>
            <span>Dashboard</span>
        </a>
        <a href='/Home/NegociosAdmin' class='nav-item group flex items-center gap-4 rounded-xl px-4 py-3.5 transition-all @(currentAction == "NegociosAdmin" ? "active" : "")'>
            <i class='fas fa-store transition group-hover:text-white text-lg w-6 text-center'></i>
            <span>Negocios</span>
        </a>
        <a href='/Home/CategoriasAdmin' class='nav-item group flex items-center gap-4 rounded-xl px-4 py-3.5 transition-all @(currentAction == "CategoriasAdmin" ? "active" : "")'>
            <i class='fas fa-tags transition group-hover:text-white text-lg w-6 text-center'></i>
            <span>Categorías</span>
        </a>
        <a href='/Home/UsuariosAdmin' class='nav-item group flex items-center gap-4 rounded-xl px-4 py-3.5 transition-all @(currentAction == "UsuariosAdmin" ? "active" : "")'>
            <i class='fas fa-user-friends transition group-hover:text-white text-lg w-6 text-center'></i>
            <span>Usuarios</span>
        </a>
        <a href='/Home/ReportesAdmin' class='nav-item group flex items-center gap-4 rounded-xl px-4 py-3.5 transition-all @(currentAction == "ReportesAdmin" ? "active" : "")'>
            <i class='fas fa-chart-line transition group-hover:text-white text-lg w-6 text-center'></i>
            <span>Reportes</span>
        </a>
        <a href='/Home/ImportarOSM' class='nav-item group flex items-center gap-4 rounded-xl px-4 py-3.5 transition-all @(currentAction == "ImportarOSM" ? "active" : "")'>
            <i class='fas fa-cloud-download-alt transition group-hover:text-white text-lg w-6 text-center'></i>
            <span>Importar OSM</span>
        </a>
    </nav>
    
</aside>